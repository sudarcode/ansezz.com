---
import BaseLayout from "@/layouts/BaseLayout.astro";
import RobotMascot from "@/components/neobrutalist/RobotMascot.astro";
import SpeechBubble from "@/components/neobrutalist/SpeechBubble.astro";
import BurstBadge from "@/components/neobrutalist/BurstBadge.astro";
---

<BaseLayout title="404 — Lost in space" description="Page not found." noindex>
  <section
    class="mx-auto max-w-5xl px-5 pt-12 pb-10 md:pt-20 md:pb-14 text-center"
  >
    <BurstBadge tone="red" size="lg" class="mb-8">404</BurstBadge>
    <h1 class="display text-[clamp(2rem,5.5vw,4rem)]">Page not found</h1>
    <p class="mt-5 text-base sm:text-lg text-ink/70 max-w-xl mx-auto">
      The page you wanted ran off with the AI hype train. Try the home page.
    </p>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-10 text-center">
    <div class="flex justify-center">
      <RobotMascot tone="yellow" size={180} />
    </div>
    <div class="mt-6 flex justify-center">
      <SpeechBubble tone="cyan" tail="tl">
        Beep boop. <span class="opacity-70">404 ERROR.</span>
      </SpeechBubble>
    </div>
    <a
      href="/"
      class="mt-10 inline-flex items-center gap-2 border-[3px] border-ink bg-pink px-6 py-3 font-bold uppercase shadow-neo-md transition-all hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-lg"
    >
      ← Take me home
    </a>
  </section>
</BaseLayout>
