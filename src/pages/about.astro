---
import Page from "@/layouts/Page.astro";
import NeoCard from "@/components/neobrutalist/NeoCard.astro";
import ChecklistBox from "@/components/neobrutalist/ChecklistBox.astro";
import BurstBadge from "@/components/neobrutalist/BurstBadge.astro";
import HalftoneSection from "@/components/neobrutalist/HalftoneSection.astro";
import TagPill from "@/components/neobrutalist/TagPill.astro";
import StickyNote from "@/components/neobrutalist/StickyNote.astro";
import SpeechBubble from "@/components/neobrutalist/SpeechBubble.astro";
import PanelDivider from "@/components/neobrutalist/PanelDivider.astro";
import NeoButton from "@/components/neobrutalist/NeoButton.astro";
import AvailabilityBadge from "@/components/neobrutalist/AvailabilityBadge.astro";
import { Icon } from "astro-icon/components";
import { ABOUT, LANGUAGES, SITE, OWNER } from "@/consts";
import { breadcrumbList } from "@/lib/seo";

const aboutBreadcrumbLd = breadcrumbList([
  { name: "Home", url: SITE.URL },
  { name: "About", url: "/about/" },
]);

const facts: { v: string; l: string; icon: string; tone: "yellow" | "pink" | "cyan" | "green" | "red" | "purple" }[] = [
  { v: "12+", l: "Years shipping", icon: "lucide:rocket", tone: "yellow" },
  { v: "60+", l: "Production builds", icon: "lucide:package-check", tone: "cyan" },
  { v: "3", l: "Continents served", icon: "lucide:globe", tone: "green" },
  { v: "10+", l: "Shopify apps (public + private)", icon: "lucide:shopping-bag", tone: "pink" },
  { v: "100%", l: "Remote since 2014", icon: "lucide:laptop", tone: "purple" },
  { v: "1", l: "Time zone (GMT+1)", icon: "lucide:clock", tone: "red" },
];

const process = [
  {
    step: "01",
    title: "Discover",
    tone: "yellow" as const,
    icon: "lucide:search",
    body: "1-week deep dive. Codebase audit, architecture review, risk + cost report, 12-week remediation plan. Honest scope before any code.",
  },
  {
    step: "02",
    title: "Build",
    tone: "pink" as const,
    icon: "lucide:hammer",
    body: "TDD with Pest. Architecture-first. Production-ready from sprint one. Daily deploys, observability, incident-ready. No demoware.",
  },
  {
    step: "03",
    title: "Hand off",
    tone: "cyan" as const,
    icon: "lucide:graduation-cap",
    body: "Docs, runbooks, eval harnesses, pair sessions with your team. Your engineers ship the next feature without me — that's the win.",
  },
];

const principles = [
  {
    title: "Ship → observe → improve",
    body: "Never ship → hope. Observability is a hard requirement, not a stretch goal.",
    icon: "lucide:eye",
    tone: "yellow" as const,
  },
  {
    title: "Tests before optimism",
    body: "TDD with Pest, every time. If it's not tested, assume it's broken.",
    icon: "lucide:shield-check",
    tone: "green" as const,
  },
  {
    title: "Boring fundamentals win",
    body: "Clean Architecture, SOLID, DDD. The smallest clever bit, only when it moves a metric.",
    icon: "lucide:layers",
    tone: "cyan" as const,
  },
  {
    title: "AI is a feature, not a religion",
    body: "Evals, cost ceilings, fallbacks. If it doesn't beat the baseline, delete it.",
    icon: "lucide:brain-circuit",
    tone: "purple" as const,
  },
  {
    title: "Async by default",
    body: "Stand-ups are a tax. Async docs, recorded looms, deep-work blocks instead.",
    icon: "lucide:message-square",
    tone: "pink" as const,
  },
  {
    title: "Protect the team",
    body: "Mentor relentlessly, hire for taste, kill churn so engineers ship work they're proud of.",
    icon: "lucide:users",
    tone: "red" as const,
  },
];

const stackByLane = [
  {
    title: "Backend",
    tone: "red" as const,
    tags: ["Laravel", "PHP 8.3", "Octane (FrankenPHP)", "Horizon", "Filament", "Pest"],
  },
  {
    title: "AI engineering",
    tone: "purple" as const,
    tags: ["Anthropic Claude", "Claude Code", "MCP", "RAG", "OpenAI", "pgvector"],
  },
  {
    title: "Shopify Plus",
    tone: "green" as const,
    tags: ["GraphQL Admin", "App Bridge", "Polaris", "Functions", "Catalog API", "Theme Extensions"],
  },
  {
    title: "Data & infra",
    tone: "cyan" as const,
    tags: ["PostgreSQL", "Redis", "Docker", "Coolify", "GitHub Actions", "Cloudflare"],
  },
];

const obsessions = [
  { label: "Anthropic MCP servers in production", done: true },
  { label: "Multi-provider LLM abstractions in PHP", done: true },
  { label: "pgvector + hybrid retrieval", done: true },
  { label: "Agentic commerce on Shopify", done: false },
  { label: "FrankenPHP worker mode tuning at scale", done: false },
];
---

<Page
  title={ABOUT.TITLE}
  description={ABOUT.DESCRIPTION}
  eyebrow="About"
  heading="Backend brain. AI heart. 12 years of shipping."
  intro="I'm Anass — senior lead backend engineer, software architect, and AI engineer. Remote-only since 2014. I help founders, agencies, and product teams ship Laravel SaaS, Shopify Plus apps, and AI features that survive real users."
  structuredData={aboutBreadcrumbLd}
>
  <section
    class="mx-auto max-w-5xl px-5 grid gap-10 md:grid-cols-[1fr_320px] md:gap-12 pb-12"
  >
    <div class="space-y-14 min-w-0">
      <div class="flex flex-wrap items-center gap-4">
        <AvailabilityBadge label={OWNER.STATUS} />
        <StickyNote tone="yellow" tilt={-3} class="max-w-[280px]">
          <p class="mono text-[10px] font-bold uppercase tracking-widest mb-1">
            ▸ Heads up
          </p>
          <p class="text-sm font-bold leading-snug">
            Remote-first since 2014. {SITE.TZ}, but I adapt to your zone.
          </p>
        </StickyNote>
      </div>

      <div>
        <BurstBadge tone="yellow" size="sm" class="mb-5">01</BurstBadge>
        <h2 class="display text-3xl md:text-4xl mb-3">
          By the numbers.
        </h2>
        <p class="text-base md:text-lg text-ink-soft mb-6 max-w-2xl">
          Receipts before opinions. The kind of numbers that hold up under
          procurement review.
        </p>
        <ul class="grid gap-4 grid-cols-2 lg:grid-cols-3">
          {
            facts.map((f, i) => (
              <li>
                <NeoCard
                  tone={f.tone}
                  shadow="sm"
                  tilt={i % 2 === 0 ? -0.4 : 0.4}
                  class="text-center flex flex-col gap-2"
                >
                  <span
                    class="inline-flex h-10 w-10 mx-auto items-center justify-center border-[2.5px] border-ink rounded-full bg-paper text-ink shadow-neo-xs"
                    aria-hidden="true"
                  >
                    <Icon name={f.icon} class="h-5 w-5" />
                  </span>
                  <p class="display text-4xl md:text-5xl leading-none">
                    {f.v}
                  </p>
                  <p class="mono text-[10px] font-bold uppercase tracking-widest opacity-80">
                    {f.l}
                  </p>
                </NeoCard>
              </li>
            ))
          }
        </ul>
      </div>

      <PanelDivider shape="zigzag" tone="yellow" />

      <div>
        <BurstBadge tone="pink" size="sm" class="mb-5">02</BurstBadge>
        <h2 class="display text-3xl md:text-4xl mb-3">
          How I actually work.
        </h2>
        <p class="text-base md:text-lg text-ink-soft mb-6 max-w-2xl">
          Three phases. No agile theater, no surprise scope creep. Boring,
          predictable, ships.
        </p>
        <ol class="grid gap-5 md:grid-cols-3">
          {
            process.map((p, i) => (
              <li>
                <NeoCard
                  tone={p.tone}
                  shadow="md"
                  tilt={i === 1 ? 0 : i === 0 ? -0.4 : 0.4}
                  class="h-full flex flex-col gap-4"
                >
                  <header class="flex items-start justify-between gap-2">
                    <span
                      class="inline-flex h-12 w-12 items-center justify-center border-[2.5px] border-ink rounded-[6px] bg-paper text-ink shadow-neo-xs"
                      aria-hidden="true"
                    >
                      <Icon name={p.icon} class="h-5 w-5" />
                    </span>
                    <span
                      class="display text-3xl md:text-4xl leading-none opacity-40"
                      aria-hidden="true"
                    >
                      {p.step}
                    </span>
                  </header>
                  <h3 class="heading text-xl md:text-2xl uppercase leading-tight">
                    {p.title}
                  </h3>
                  <p class="text-sm leading-snug opacity-90">{p.body}</p>
                </NeoCard>
              </li>
            ))
          }
        </ol>
      </div>

      <PanelDivider shape="bolt" tone="pink" />

      <div>
        <BurstBadge tone="cyan" size="sm" class="mb-5">03</BurstBadge>
        <h2 class="display text-3xl md:text-4xl mb-5">
          From PHP scripts to AI agents.
        </h2>
        <div class="space-y-5 text-base md:text-lg leading-relaxed text-ink-soft max-w-2xl">
          <p>
            Twelve years building products for teams that needed them to work.
            Not in a demo, not in a slide deck — on day three, when the cron
            job dies and the customer is angry. That taught me the rule I still
            ship by: observable infra costs less than incident response, and
            async architecture beats timezone friction every time.
          </p>
          <SpeechBubble tone="yellow" tail="bl" class="my-2">
            <span
              class="text-base md:text-lg leading-snug block max-w-xl"
            >
              "Boring fundamentals, opinionated defaults, the smallest clever
              bit that moves a metric."
            </span>
          </SpeechBubble>
          <p>
            Started shipping web apps in 2012, went remote in 2014, never
            opened an office calendar invite again. Trajectory: generalist →
            backend specialist → lead engineer → architect → AI engineer.
            Tools changed; the rule didn't — ship something real, then make it
            survive production.
          </p>
          <p>
            Today: split across Laravel architecture, Shopify Plus app
            engineering, and agentic AI builds (Claude, MCP, RAG). Plus the
            open-source pieces that keep all three honest — provider
            abstractions, MCP servers, eval harnesses wired into Claude Code.
          </p>
        </div>
      </div>

      <PanelDivider shape="dots" tone="cyan" />

      <div>
        <BurstBadge tone="purple" size="sm" class="mb-5">04</BurstBadge>
        <h2 class="display text-3xl md:text-4xl mb-3">Operating principles.</h2>
        <p class="text-base md:text-lg text-ink-soft mb-6 max-w-2xl">
          The rules that survived twelve years. Boring on purpose. Hard to
          argue with under pressure.
        </p>
        <ul class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {
            principles.map((p, i) => (
              <li>
                <NeoCard
                  tone={p.tone}
                  shadow="sm"
                  tilt={i % 2 === 0 ? -0.3 : 0.3}
                  class="h-full flex flex-col gap-3"
                >
                  <span
                    class="inline-flex h-10 w-10 items-center justify-center border-[2.5px] border-ink rounded-full bg-paper text-ink shadow-neo-xs"
                    aria-hidden="true"
                  >
                    <Icon name={p.icon} class="h-5 w-5" />
                  </span>
                  <h3 class="heading text-base uppercase leading-tight">
                    {p.title}
                  </h3>
                  <p class="text-sm leading-snug opacity-90">{p.body}</p>
                </NeoCard>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <BurstBadge tone="green" size="sm" class="mb-5">05</BurstBadge>
        <h2 class="display text-3xl md:text-4xl mb-3">Stack, at a glance.</h2>
        <p class="text-base md:text-lg text-ink-soft mb-6 max-w-2xl">
          Full list lives on <a class="font-bold underline underline-offset-4 decoration-[3px] hover:bg-yellow px-0.5" href="/uses/">/uses</a> — here are the lanes.
        </p>
        <ul class="grid gap-5 md:grid-cols-2">
          {
            stackByLane.map((s, i) => (
              <li>
                <NeoCard
                  tone={s.tone}
                  shadow="sm"
                  tilt={i % 2 === 0 ? -0.3 : 0.3}
                  class="h-full"
                >
                  <h3 class="heading text-lg uppercase mb-3">{s.title}</h3>
                  <ul class="flex flex-wrap gap-1.5">
                    {s.tags.map((t) => (
                      <li>
                        <TagPill tone="paper" size="sm">
                          {t}
                        </TagPill>
                      </li>
                    ))}
                  </ul>
                </NeoCard>
              </li>
            ))
          }
        </ul>
      </div>

      <div class="grid gap-6 sm:grid-cols-3">
        <div>
          <p
            class="mono text-xs font-bold uppercase tracking-widest opacity-60 mb-3"
          >
            ▸ Languages
          </p>
          <ul class="flex flex-wrap gap-2">
            {
              LANGUAGES.map((l) => (
                <li>
                  <TagPill tone="paper" size="sm">
                    <span class="font-black">{l.label}</span>
                    <span class="mono opacity-70 ml-2">{l.level}</span>
                  </TagPill>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <p
            class="mono text-xs font-bold uppercase tracking-widest opacity-60 mb-3"
          >
            ▸ Based in
          </p>
          <ul class="flex flex-wrap gap-2">
            <li><TagPill tone="cyan" size="sm">{SITE.LOCATION}</TagPill></li>
            <li><TagPill tone="paper" size="sm">{SITE.TZ}</TagPill></li>
          </ul>
        </div>
        <div>
          <p
            class="mono text-xs font-bold uppercase tracking-widest opacity-60 mb-3"
          >
            ▸ Mode
          </p>
          <ul class="flex flex-wrap gap-2">
            <li><TagPill tone="green" size="sm">Remote-only</TagPill></li>
            <li><TagPill tone="yellow" size="sm">Async-friendly</TagPill></li>
            <li><TagPill tone="pink" size="sm">Long engagements</TagPill></li>
          </ul>
        </div>
      </div>
    </div>

    <aside class="md:sticky md:top-24 md:self-start space-y-5">
      <ChecklistBox
        title="Currently obsessed with"
        items={obsessions}
        tone="yellow"
      />
      <NeoCard tone="paper" class="space-y-4">
        <p
          class="mono text-xs font-bold uppercase tracking-widest text-pink-deep"
        >
          ▸ For procurement / recruiters
        </p>
        <p class="text-sm leading-snug">
          Resume has every role, stack, and outcome — the version that survives
          ATS.
        </p>
        <NeoButton
          href={SITE.RESUME_URL}
          variant="primary"
          size="md"
          fullWidth
          ariaLabel="Download resume PDF"
        >
          <Icon name="lucide:download" class="h-4 w-4" />
          Download resume (PDF)
        </NeoButton>
        <NeoButton href="/contact/" variant="ink" size="md" fullWidth>
          <Icon name="lucide:mail" class="h-4 w-4" />
          Hire me →
        </NeoButton>
      </NeoCard>
    </aside>
  </section>

  <HalftoneSection tone="ink" bordered class="py-14">
    <div class="mx-auto max-w-5xl px-5 text-center text-bg">
      <p class="display text-3xl md:text-4xl mb-4">Got a project in mind?</p>
      <p class="text-bg/80 mb-6 max-w-xl mx-auto">
        I take on a handful of senior / lead / advisory engagements each year.
        First call is on me — I'll tell you honestly if it's a fit.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-4">
        <NeoButton href="/contact/" variant="danger" size="lg">
          <Icon name="lucide:mail" class="h-4 w-4" />
          Get in touch →
        </NeoButton>
        <NeoButton href={SITE.BOOKING_URL} variant="primary" size="lg">
          <Icon name="lucide:calendar" class="h-4 w-4" />
          Book a 15-min intro
        </NeoButton>
      </div>
    </div>
  </HalftoneSection>
</Page>
