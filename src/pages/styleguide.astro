---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NeoCard from "@/components/neobrutalist/NeoCard.astro";
import NeoButton from "@/components/neobrutalist/NeoButton.astro";
import SpeechBubble from "@/components/neobrutalist/SpeechBubble.astro";
import HalftoneSection from "@/components/neobrutalist/HalftoneSection.astro";
import BurstBadge from "@/components/neobrutalist/BurstBadge.astro";
import StickyNote from "@/components/neobrutalist/StickyNote.astro";
import TagPill from "@/components/neobrutalist/TagPill.astro";
import TagPillRow from "@/components/neobrutalist/TagPillRow.astro";
import PageNumber from "@/components/neobrutalist/PageNumber.astro";
import ChecklistBox from "@/components/neobrutalist/ChecklistBox.astro";
import ComparisonTable from "@/components/neobrutalist/ComparisonTable.astro";
import CodeBlock from "@/components/neobrutalist/CodeBlock.astro";
import RobotMascot from "@/components/neobrutalist/RobotMascot.astro";
import SocialButton from "@/components/neobrutalist/SocialButton.astro";
import AvailabilityBadge from "@/components/neobrutalist/AvailabilityBadge.astro";
import PanelDivider from "@/components/neobrutalist/PanelDivider.astro";
import NewsletterCallout from "@/components/home/NewsletterCallout.astro";
import { Icon } from "astro-icon/components";

const sample = `import { Anthropic } from "@anthropic-ai/sdk";

const client = new Anthropic();

const response = await client.messages.create({
  model: "claude-opus-4-7",
  max_tokens: 1024,
  messages: [{ role: "user", content: "Ship it." }],
});
`;

const cols = [
  { label: "NeoCard", tone: "yellow" as const },
  { label: "Old card", tone: "blue" as const },
  { label: "Plain div", tone: "red" as const },
];

const rows = [
  { icon: "lucide:zap", label: "Hard shadow", cells: [true, false, false] },
  { icon: "lucide:square", label: "Thick border", cells: [true, true, false] },
  { icon: "lucide:rotate-cw", label: "Hover lift", cells: [true, false, false] },
  { icon: "lucide:smile", label: "Personality", cells: [true, false, false] },
];

const checklist = [
  { label: "Build 15 neobrutalist primitives", done: true },
  { label: "Build 5 composites", done: true },
  { label: "Wire base layout", done: true },
  { label: "Stub all pages", done: true },
  { label: "Write real blog posts", done: false },
  { label: "Ship OG image generator", done: false },
];

interface ColorToken {
  name: string;
  value: string;
  className: string;
  text?: string;
}

const colors: ColorToken[] = [
  { name: "bg", value: "#fafaf5", className: "bg-bg" },
  { name: "bg-alt", value: "#f0efe6", className: "bg-bg-alt" },
  { name: "paper", value: "#ffffff", className: "bg-paper" },
  { name: "ink", value: "#0a0a0a", className: "bg-ink", text: "text-paper" },
  { name: "ink-soft", value: "#2a2a2a", className: "bg-ink-soft", text: "text-paper" },
  { name: "yellow", value: "#ffd93d", className: "bg-yellow" },
  { name: "pink", value: "#ff2d87", className: "bg-pink", text: "text-paper" },
  { name: "pink-deep", value: "#c7005f", className: "bg-pink-deep", text: "text-paper" },
  { name: "cyan", value: "#3dd9c9", className: "bg-cyan" },
  { name: "green", value: "#7ae582", className: "bg-green" },
  { name: "red", value: "#ff5a5f", className: "bg-red" },
  { name: "blue", value: "#2e6bb8", className: "bg-blue", text: "text-paper" },
  { name: "purple", value: "#9b5de5", className: "bg-purple", text: "text-paper" },
];

const shadows = ["xs", "sm", "md", "lg", "xl"] as const;

const sections = [
  { id: "tokens-color", label: "Colors" },
  { id: "tokens-shadow", label: "Shadows" },
  { id: "tokens-type", label: "Type" },
  { id: "neocard", label: "NeoCard" },
  { id: "neobutton", label: "NeoButton" },
  { id: "tagpill", label: "TagPill" },
  { id: "burstbadge", label: "BurstBadge" },
  { id: "speechbubble", label: "SpeechBubble" },
  { id: "stickynote", label: "StickyNote" },
  { id: "pagenumber", label: "PageNumber" },
  { id: "halftone", label: "Halftone" },
  { id: "paneldivider", label: "PanelDivider" },
  { id: "checklistbox", label: "ChecklistBox" },
  { id: "comparison", label: "ComparisonTable" },
  { id: "codeblock", label: "CodeBlock" },
  { id: "tagpillrow", label: "TagPillRow" },
  { id: "availability", label: "AvailabilityBadge" },
  { id: "socialbutton", label: "SocialButton" },
  { id: "mascot", label: "RobotMascot" },
  { id: "newsletter", label: "NewsletterCallout" },
];
---

<BaseLayout title="Styleguide" description="Component playground." noindex>
  <section class="relative mx-auto max-w-5xl px-5 py-12">
    <PageNumber n="00" position="tr" />
    <p class="mono text-sm font-bold uppercase tracking-widest text-pink-deep mb-3">
      ▸ Internal · v2
    </p>
    <h1 class="display text-[clamp(3rem,8vw,7rem)] leading-[0.92]">
      Styleguide
    </h1>
    <p class="mt-4 max-w-2xl text-lg opacity-70">
      Every neobrutalist component, every variant, in one place.
    </p>
    <nav class="mt-8 flex flex-wrap gap-2" aria-label="Styleguide sections">
      {
        sections.map((s) => (
          <a
            href={`#${s.id}`}
            class="inline-flex items-center border-[2px] border-ink bg-paper rounded-full px-3 py-1 text-xs font-bold uppercase hover:bg-yellow transition-colors"
          >
            {s.label}
          </a>
        ))
      }
    </nav>
  </section>

  <section class="mx-auto max-w-5xl px-5 py-10 space-y-16">
    <div id="tokens-color">
      <h2 class="display text-3xl mb-5">Color tokens</h2>
      <ul class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 gap-3">
        {colors.map((c) => (
          <li class:list={["border-[3px] border-ink rounded-[4px] overflow-hidden shadow-neo-xs", c.className, c.text ?? "text-ink"]}>
            <div class="h-20 w-full"></div>
            <div class="bg-paper text-ink border-t-[3px] border-ink px-3 py-2">
              <p class="mono text-[11px] font-bold uppercase tracking-widest">{c.name}</p>
              <p class="mono text-[10px] opacity-60">{c.value}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <div id="tokens-shadow">
      <h2 class="display text-3xl mb-5">Shadow tokens</h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-6">
        {shadows.map((s) => (
          <div class="flex flex-col items-start gap-3">
            <div class:list={["h-20 w-full border-[3px] border-ink rounded-[4px] bg-paper", `shadow-neo-${s}`]}></div>
            <p class="mono text-[11px] font-bold uppercase tracking-widest">shadow-neo-{s}</p>
          </div>
        ))}
      </div>
    </div>

    <div id="tokens-type">
      <h2 class="display text-3xl mb-5">Type scale</h2>
      <div class="space-y-5">
        <div class="border-[3px] border-ink rounded-[4px] bg-paper p-5">
          <p class="mono text-[10px] font-bold uppercase tracking-widest opacity-60 mb-2">display-xl</p>
          <p class="display" style="font-size: var(--type-display-xl); line-height: 0.92;">Ship it.</p>
        </div>
        <div class="border-[3px] border-ink rounded-[4px] bg-paper p-5">
          <p class="mono text-[10px] font-bold uppercase tracking-widest opacity-60 mb-2">display-l</p>
          <p class="display" style="font-size: var(--type-display-l); line-height: 1;">Sub-headline goes here.</p>
        </div>
        <div class="border-[3px] border-ink rounded-[4px] bg-paper p-5">
          <p class="mono text-[10px] font-bold uppercase tracking-widest opacity-60 mb-2">display-m</p>
          <p class="display" style="font-size: var(--type-display-m); line-height: 1.05;">Section heading text.</p>
        </div>
        <div class="border-[3px] border-ink rounded-[4px] bg-paper p-5 space-y-2">
          <p class="mono text-[10px] font-bold uppercase tracking-widest opacity-60">Body + mono</p>
          <p class="text-base">Body text — readable body sample with <strong>strong</strong> + <em>emphasis</em>.</p>
          <p class="mono text-sm">mono · IBM Plex Mono · keys, code, labels</p>
          <p class="text-sm opacity-70">text-sm opacity-70 · meta + caption text</p>
        </div>
      </div>
    </div>

    <div id="neocard">
      <h2 class="display text-3xl mb-5">NeoCard — tones</h2>
      <div class="grid gap-5 sm:grid-cols-2 md:grid-cols-4">
        <NeoCard tone="paper">Paper</NeoCard>
        <NeoCard tone="yellow">Yellow</NeoCard>
        <NeoCard tone="pink">Pink</NeoCard>
        <NeoCard tone="cyan">Cyan</NeoCard>
        <NeoCard tone="green">Green</NeoCard>
        <NeoCard tone="red">Red</NeoCard>
        <NeoCard tone="blue">Blue</NeoCard>
        <NeoCard tone="purple">Purple</NeoCard>
        <NeoCard tone="ink">Ink</NeoCard>
      </div>
      <h3 class="heading text-lg uppercase mt-8 mb-3">Hoverable + tilted</h3>
      <div class="grid gap-5 sm:grid-cols-3">
        <NeoCard tone="yellow" hover tilt={-1}>Hover me (tilt -1)</NeoCard>
        <NeoCard tone="pink" hover>Hover me (flat)</NeoCard>
        <NeoCard tone="cyan" hover tilt={1.5}>Hover me (tilt +1.5)</NeoCard>
      </div>
    </div>

    <div id="neobutton">
      <h2 class="display text-3xl mb-5">NeoButton — variants × sizes</h2>
      <div class="space-y-4">
        <div class="flex flex-wrap gap-3 items-center">
          <NeoButton variant="primary" size="sm">Primary sm</NeoButton>
          <NeoButton variant="primary" size="md">Primary md</NeoButton>
          <NeoButton variant="primary" size="lg">Primary lg</NeoButton>
        </div>
        <div class="flex flex-wrap gap-3 items-center">
          <NeoButton variant="secondary">Secondary</NeoButton>
          <NeoButton variant="ghost">Ghost</NeoButton>
          <NeoButton variant="danger">Danger</NeoButton>
          <NeoButton variant="ink">Ink</NeoButton>
          <NeoButton variant="primary" disabled>Disabled</NeoButton>
        </div>
        <div class="flex flex-wrap gap-3 items-center">
          <NeoButton variant="primary" href="/blog/">
            <Icon name="lucide:book-open" class="h-4 w-4" />
            With icon
          </NeoButton>
          <NeoButton variant="ink" fullWidth class="max-w-xs">
            Full width
          </NeoButton>
        </div>
      </div>
    </div>

    <div id="tagpill">
      <h2 class="display text-3xl mb-5">TagPill</h2>
      <div class="flex flex-wrap gap-2">
        <TagPill tone="yellow">Laravel</TagPill>
        <TagPill tone="pink">AI</TagPill>
        <TagPill tone="cyan">Shopify</TagPill>
        <TagPill tone="green">Open source</TagPill>
        <TagPill tone="red">DevOps</TagPill>
        <TagPill tone="blue">Architecture</TagPill>
        <TagPill tone="purple">Agentic</TagPill>
        <TagPill tone="ink">Hot take</TagPill>
        <TagPill tone="paper">Paper</TagPill>
        <TagPill tone="yellow" href="#">Clickable</TagPill>
        <TagPill tone="yellow" size="sm">Small</TagPill>
        <TagPill tone="ink" active>Active</TagPill>
      </div>
    </div>

    <div id="burstbadge">
      <h2 class="display text-3xl mb-5">BurstBadge — sizes × tones</h2>
      <div class="flex flex-wrap items-center gap-6">
        <BurstBadge tone="yellow" size="sm">01</BurstBadge>
        <BurstBadge tone="pink">02</BurstBadge>
        <BurstBadge tone="cyan" size="lg">NEW</BurstBadge>
        <BurstBadge tone="green">SHIP</BurstBadge>
        <BurstBadge tone="red" size="lg">404</BurstBadge>
        <BurstBadge tone="blue">AI</BurstBadge>
      </div>
    </div>

    <div id="speechbubble">
      <h2 class="display text-3xl mb-5">SpeechBubble — tones × tails</h2>
      <div class="flex flex-wrap gap-8">
        <SpeechBubble tone="yellow">Bottom-left (default).</SpeechBubble>
        <SpeechBubble tone="pink" tail="br">Bottom-right tail.</SpeechBubble>
        <SpeechBubble tone="cyan" tail="tl">Top-left tail.</SpeechBubble>
        <SpeechBubble tone="green" tail="tr">Top-right tail.</SpeechBubble>
        <SpeechBubble tone="paper">Paper</SpeechBubble>
      </div>
    </div>

    <div id="stickynote">
      <h2 class="display text-3xl mb-5">StickyNote — tilt &amp; tones</h2>
      <div class="flex flex-wrap gap-6">
        <StickyNote tone="yellow" tilt={-3}>
          <p class="font-bold">Remember to ship.</p>
        </StickyNote>
        <StickyNote tone="pink" tilt={2}>
          <p class="font-bold">Sleep is for the weak (j/k, sleep).</p>
        </StickyNote>
        <StickyNote tone="cyan" tilt={-1}>
          <p class="font-bold">PR review at 14h.</p>
        </StickyNote>
        <StickyNote tone="green" tilt={3}>
          <p class="font-bold">Refactor task #47.</p>
        </StickyNote>
      </div>
    </div>

    <div id="pagenumber">
      <h2 class="display text-3xl mb-5">PageNumber — positions</h2>
      <div class="grid gap-5 md:grid-cols-2">
        {
          (["tl", "tr", "bl", "br"] as const).map((p) => (
            <div class="relative border-[3px] border-ink bg-paper rounded-[4px] h-40 overflow-hidden">
              <PageNumber n={p.toUpperCase()} position={p} />
              <p class="absolute bottom-2 left-3 mono text-xs font-bold uppercase tracking-widest opacity-70">
                position="{p}"
              </p>
            </div>
          ))
        }
      </div>
    </div>

    <div id="halftone" class="-mx-5">
      <h2 class="display text-3xl mb-5 px-5">HalftoneSection</h2>
      <HalftoneSection tone="blue" bordered class="py-10 text-paper">
        <p class="text-center display text-2xl px-5">Blue tone, default density</p>
      </HalftoneSection>
      <HalftoneSection tone="yellow" dense bordered class="py-10 mt-1">
        <p class="text-center display text-2xl px-5">Yellow tone, dense</p>
      </HalftoneSection>
    </div>

    <div id="paneldivider">
      <h2 class="display text-3xl mb-5">PanelDivider — shapes</h2>
      <PanelDivider shape="zigzag" tone="yellow" />
      <PanelDivider shape="bolt" tone="pink" />
      <PanelDivider shape="burst" tone="cyan" />
      <PanelDivider shape="dots" tone="green" />
    </div>

    <div id="checklistbox">
      <h2 class="display text-3xl mb-5">ChecklistBox</h2>
      <div class="grid gap-5 md:grid-cols-2">
        <ChecklistBox title="Phase progress" items={checklist} tone="yellow" />
        <ChecklistBox title="Cyan variant" items={checklist.slice(0, 3)} tone="cyan" />
      </div>
    </div>

    <div id="comparison">
      <h2 class="display text-3xl mb-5">ComparisonTable</h2>
      <ComparisonTable columns={cols} rows={rows} />
    </div>

    <div id="codeblock">
      <h2 class="display text-3xl mb-5">CodeBlock</h2>
      <CodeBlock code={sample} lang="ts" filename="anthropic.ts" />
    </div>

    <div id="tagpillrow">
      <h2 class="display text-3xl mb-5">TagPillRow</h2>
      <TagPillRow label="Scroll on mobile" scrollOnMobile>
        <li><TagPill tone="yellow">Laravel</TagPill></li>
        <li><TagPill tone="pink">PHP</TagPill></li>
        <li><TagPill tone="cyan">Octane</TagPill></li>
        <li><TagPill tone="green">Filament</TagPill></li>
        <li><TagPill tone="red">Horizon</TagPill></li>
        <li><TagPill tone="blue">PostgreSQL</TagPill></li>
        <li><TagPill tone="purple">pgvector</TagPill></li>
        <li><TagPill tone="ink">Redis</TagPill></li>
      </TagPillRow>
    </div>

    <div id="availability">
      <h2 class="display text-3xl mb-5">AvailabilityBadge</h2>
      <div class="flex flex-wrap gap-5 items-center">
        <AvailabilityBadge />
        <AvailabilityBadge label="Open · Q3 2026" />
        <AvailabilityBadge label="Booked through August" available={false} />
      </div>
    </div>

    <div id="socialbutton">
      <h2 class="display text-3xl mb-5">SocialButton — sizes × tones</h2>
      <div class="flex flex-wrap items-end gap-5">
        <SocialButton href="https://github.com/ansezz" icon="lucide:github" label="GitHub" tone="paper" size="sm" />
        <SocialButton href="https://github.com/ansezz" icon="lucide:github" label="GitHub" tone="paper" size="md" />
        <SocialButton href="https://github.com/ansezz" icon="lucide:github" label="GitHub" tone="paper" size="lg" />
        <SocialButton href="https://linkedin.com/in/ansezz" icon="lucide:linkedin" label="LinkedIn" tone="cyan" size="md" />
        <SocialButton href="mailto:hello@ansezz.com" icon="lucide:mail" label="Email" tone="yellow" size="md" />
        <SocialButton href="/rss.xml" icon="lucide:rss" label="RSS" tone="pink" size="md" />
        <SocialButton href="#" icon="lucide:youtube" label="YouTube" tone="purple" size="md" />
        <SocialButton href="#" icon="lucide:terminal" label="Terminal" tone="ink" size="md" />
      </div>
    </div>

    <div id="mascot">
      <h2 class="display text-3xl mb-5">RobotMascot — tones</h2>
      <div class="flex flex-wrap gap-6 items-end">
        <RobotMascot tone="yellow" />
        <RobotMascot tone="pink" />
        <RobotMascot tone="cyan" />
        <RobotMascot tone="green" />
      </div>
    </div>
  </section>

  <div id="newsletter">
    <NewsletterCallout />
  </div>
</BaseLayout>
