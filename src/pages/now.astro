---
import Page from "@/layouts/Page.astro";
import NeoCard from "@/components/neobrutalist/NeoCard.astro";
import NeoButton from "@/components/neobrutalist/NeoButton.astro";
import StickyNote from "@/components/neobrutalist/StickyNote.astro";
import { Icon } from "astro-icon/components";
import { NOW, OWNER, SITE } from "@/consts";
import { breadcrumbList } from "@/lib/seo";

const breadcrumbLd = breadcrumbList([
  { name: "Home", url: SITE.URL },
  { name: "Now", url: "/now/" },
]);

const updated = new Date(NOW.UPDATED).toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Page
  title={NOW.TITLE}
  description={NOW.DESCRIPTION}
  eyebrow="Now"
  heading="What I'm doing now."
  intro="A snapshot of what has my attention this season — borrowed from Derek Sivers' /now page idea."
  structuredData={breadcrumbLd}
>
  <section class="mx-auto max-w-5xl px-5 pb-6">
    <StickyNote tone="yellow" tilt={-1.5} class="max-w-md">
      <p class="mono text-[10px] font-bold uppercase tracking-widest mb-1">
        ▸ Last updated
      </p>
      <p class="text-sm font-bold leading-snug">
        {updated} — from {SITE.LOCATION} ({SITE.TZ}).
      </p>
    </StickyNote>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-12">
    <ul class="grid gap-6 md:grid-cols-2">
      {
        NOW.FOCUS.map((f, i) => (
          <li>
            <NeoCard
              tone={f.tone}
              shadow="md"
              tilt={i % 2 === 0 ? -0.3 : 0.3}
              class="flex h-full flex-col gap-3"
            >
              <span
                class="inline-flex h-11 w-11 items-center justify-center border-[2.5px] border-ink rounded-[6px] bg-paper text-ink shadow-neo-xs"
                aria-hidden="true"
              >
                <Icon name={f.icon} class="h-5 w-5" />
              </span>
              <h2 class="heading text-xl uppercase leading-tight">
                {f.title}
              </h2>
              <p class="text-sm md:text-base leading-snug opacity-90">
                {f.body}
              </p>
            </NeoCard>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-16">
    <NeoCard tone="paper" class="text-center space-y-4">
      <p class="mono text-xs font-bold uppercase tracking-widest text-pink-deep">
        ▸ Want the long version?
      </p>
      <p class="text-base md:text-lg max-w-2xl mx-auto leading-snug">
        {OWNER.CURRENTLY}
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
        <NeoButton href="/work/" variant="primary" size="lg">
          See the work →
        </NeoButton>
        <NeoButton href="/contact/" variant="ink" size="lg">
          <Icon name="lucide:mail" class="h-4 w-4" />
          Get in touch
        </NeoButton>
      </div>
    </NeoCard>
  </section>
</Page>
