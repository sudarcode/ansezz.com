---
import Page from "@/layouts/Page.astro";
import NeoCard from "@/components/neobrutalist/NeoCard.astro";
import TagPill from "@/components/neobrutalist/TagPill.astro";
import TagPillRow from "@/components/neobrutalist/TagPillRow.astro";
import HalftoneSection from "@/components/neobrutalist/HalftoneSection.astro";
import SocialButton from "@/components/neobrutalist/SocialButton.astro";
import AvailabilityBadge from "@/components/neobrutalist/AvailabilityBadge.astro";
import PanelDivider from "@/components/neobrutalist/PanelDivider.astro";
import BurstBadge from "@/components/neobrutalist/BurstBadge.astro";
import StickyNote from "@/components/neobrutalist/StickyNote.astro";
import SpeechBubble from "@/components/neobrutalist/SpeechBubble.astro";
import RobotMascot from "@/components/neobrutalist/RobotMascot.astro";
import { Icon } from "astro-icon/components";
import { CONTACT, SITE, AVAILABLE_FOR, OWNER, SERVICES } from "@/consts";
import { faqPage, breadcrumbList } from "@/lib/seo";

const tones = ["yellow", "pink", "cyan", "green", "red", "blue", "purple"] as const;

const flow = [
  {
    step: "01",
    title: "Send a short email",
    icon: "lucide:mail",
    tone: "yellow" as const,
    body: "Couple of paragraphs. Problem, rough timeline, link to the product if it exists. No big spec needed.",
  },
  {
    step: "02",
    title: "15-min intro call",
    icon: "lucide:phone-call",
    tone: "pink" as const,
    body: "Free. We see if it's a fit — scope, stack, stakes, my honest take on whether I'm the right person.",
  },
  {
    step: "03",
    title: "Scoped proposal",
    icon: "lucide:clipboard-list",
    tone: "cyan" as const,
    body: "Within 48h: phased plan, milestones, deliverables, fixed price or weekly retainer — your pick.",
  },
];

const bestFor = [
  "Founders shipping a Laravel SaaS MVP",
  "Teams stuck on multi-tenant architecture",
  "Shopify Plus brands needing custom apps",
  "Agencies adding AI features without an in-house ML team",
  "CTOs wanting an honest architecture audit",
  "Existing apps fighting Octane / queues / observability",
];

const notFor = [
  "Pure WordPress / no-code work",
  "Mobile-only native apps",
  "Pixel-perfect static landing-page sprints",
  "Crypto / NFT projects",
];

const faq = [
  {
    q: "Are you available right now?",
    a: "I keep 1–2 senior slots open per quarter. Current status sits in the badge at the top — if it says Open, I have capacity.",
  },
  {
    q: "Do you sign NDAs?",
    a: "Yes, standard mutual NDAs before the second call. I won't sign one-sided gag orders or anything that prevents me from listing the work as a portfolio entry (technology-only, no client name) after launch.",
  },
  {
    q: "How do you bill?",
    a: "Fixed-price per phase for scoped work; weekly retainer for ongoing engagements (typically 20–30 hrs/week). USD invoicing via Wise or Stripe. EU VAT handled.",
  },
  {
    q: "What's your time zone?",
    a: "GMT+1 (Morocco). Overlap windows: EU 09–13 CET · US East 14–18 CET. Pacific teams handled async with 1–2 weekly sync hours. Async-first always — replies in ≤24h on weekdays.",
  },
  {
    q: "Will you take an equity-only project?",
    a: "Only if I'm already convinced (cap-table fit, founder fit, traction). Cash + equity hybrids: open to discussing. Pure equity: rare.",
  },
  {
    q: "Can I see code samples?",
    a: "Yes — public work on /work, GitHub for OSS contributions. Production code is under NDA; I can walk through architecture decisions on a call.",
  },
];
---

<Page
  title={CONTACT.TITLE}
  description={CONTACT.DESCRIPTION}
  eyebrow="Hire me"
  heading="Let's build something."
  intro="Senior backend, software architect, AI engineer. Booked weekly, but I keep slots for serious projects. Two ways to start — email me, or book a 15-min intro."
  structuredData={[
    faqPage(faq.map((item) => ({ question: item.q, answer: item.a }))),
    breadcrumbList([
      { name: "Home", url: SITE.URL },
      { name: "Contact", url: "/contact/" },
    ]),
  ]}
>
  <section class="mx-auto max-w-5xl px-5 pb-12 space-y-6">
    <div class="flex flex-wrap items-center gap-4">
      <AvailabilityBadge label={OWNER.STATUS} />
      <StickyNote tone="yellow" tilt={-2} class="max-w-[280px]">
        <p class="mono text-[10px] font-bold uppercase tracking-widest mb-1">
          ▸ Response window
        </p>
        <p class="text-sm font-bold leading-snug">
          Email: ≤ 24h on weekdays. First call ≤ 5 business days.
        </p>
      </StickyNote>
    </div>

    <ul class="grid gap-5 md:grid-cols-2">
      <li>
        <NeoCard
          href={`mailto:${SITE.EMAIL}?subject=Project inquiry`}
          tone="yellow"
          hover
          shadow="lg"
          ariaLabel="Send email"
          class="h-full"
        >
          <div class="flex items-start gap-4">
            <span
              class="inline-flex h-14 w-14 items-center justify-center border-[2.5px] border-ink rounded-[6px] bg-paper text-ink shadow-neo-xs"
              aria-hidden="true"
            >
              <Icon name="lucide:mail" class="h-6 w-6" />
            </span>
            <div class="flex-1 min-w-0">
              <p class="mono text-[11px] font-bold uppercase tracking-widest opacity-70 mb-1">
                ▸ Option A · fastest
              </p>
              <p class="display text-2xl md:text-3xl leading-tight mb-2">
                Send an email
              </p>
              <p class="font-bold inline-flex items-center gap-1.5">
                Open your mail app
                <Icon name="lucide:arrow-up-right" class="h-4 w-4" />
              </p>
              <p class="text-sm mt-2 opacity-80">
                2–3 sentences on scope. Reply within 24h on weekdays.
              </p>
            </div>
          </div>
        </NeoCard>
      </li>
      <li>
        <NeoCard
          href={SITE.BOOKING_URL}
          tone="ink"
          hover
          shadow="lg"
          ariaLabel="Book 15-minute intro call"
          class="h-full text-bg"
        >
          <div class="flex items-start gap-4">
            <span
              class="inline-flex h-14 w-14 items-center justify-center border-[2.5px] border-bg rounded-[6px] bg-yellow text-ink shadow-neo-xs"
              aria-hidden="true"
            >
              <Icon name="lucide:calendar" class="h-6 w-6" />
            </span>
            <div class="flex-1 min-w-0">
              <p class="mono text-[11px] font-bold uppercase tracking-widest opacity-60 mb-1">
                ▸ Option B · skip the email
              </p>
              <p class="display text-2xl md:text-3xl leading-tight mb-2">
                Book a 15-min call
              </p>
              <p class="font-bold">Google Calendar · pick a slot</p>
              <p class="text-sm mt-2 opacity-70">
                Free. Honest. No deck, no pitch.
              </p>
            </div>
          </div>
        </NeoCard>
      </li>
    </ul>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-16">
    <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-end mb-8">
      <div class="max-w-2xl">
        <BurstBadge tone="cyan" size="sm" class="mb-4">01</BurstBadge>
        <h2 class="display text-3xl md:text-4xl leading-tight">
          How a typical engagement starts.
        </h2>
        <p class="mt-3 text-base md:text-lg text-ink-soft leading-snug">
          Three small steps, then we're either building or you have a clear no.
          Both outcomes are useful.
        </p>
      </div>
    </div>
    <ol class="grid gap-5 md:grid-cols-3">
      {
        flow.map((f, i) => (
          <li>
            <NeoCard
              tone={f.tone}
              shadow="md"
              tilt={i === 1 ? 0 : i === 0 ? -0.4 : 0.4}
              class="h-full flex flex-col gap-4"
            >
              <header class="flex items-start justify-between gap-2">
                <span
                  class="inline-flex h-12 w-12 items-center justify-center border-[2.5px] border-ink rounded-[6px] bg-paper text-ink shadow-neo-xs"
                  aria-hidden="true"
                >
                  <Icon name={f.icon} class="h-5 w-5" />
                </span>
                <span
                  class="display text-3xl md:text-4xl leading-none opacity-40"
                  aria-hidden="true"
                >
                  {f.step}
                </span>
              </header>
              <h3 class="heading text-xl md:text-2xl uppercase leading-tight">
                {f.title}
              </h3>
              <p class="text-sm leading-snug opacity-90">{f.body}</p>
            </NeoCard>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-16">
    <div class="mb-8 max-w-2xl">
      <BurstBadge tone="pink" size="sm" class="mb-4">02</BurstBadge>
      <h2 class="display text-3xl md:text-4xl leading-tight">
        Pick a lane to make scoping easy.
      </h2>
      <p class="mt-3 text-base md:text-lg text-ink-soft leading-snug">
        Most clients pick one. Some stack two. All are scoped and time-boxed.
      </p>
    </div>
    <ul class="grid gap-5 md:grid-cols-2">
      {
        SERVICES.map((s, i) => (
          <li>
            <NeoCard
              tone={s.tone}
              shadow="md"
              tilt={i % 2 === 0 ? -0.3 : 0.3}
              class="h-full flex flex-col gap-3"
            >
              <h3 class="heading text-xl uppercase leading-tight">{s.title}</h3>
              <p class="text-sm opacity-90 leading-snug">{s.body}</p>
              <ul class="space-y-1.5 text-sm mt-1">
                {s.bullets.map((b) => (
                  <li class="flex items-start gap-2">
                    <Icon
                      name="lucide:check"
                      class="h-4 w-4 mt-1 shrink-0 opacity-80"
                    />
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
            </NeoCard>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-16">
    <div class="mb-8 max-w-2xl">
      <BurstBadge tone="yellow" size="sm" class="mb-4">03</BurstBadge>
      <h2 class="display text-3xl md:text-4xl leading-tight">
        Best for. Not for.
      </h2>
      <p class="mt-3 text-base md:text-lg text-ink-soft leading-snug">
        Saves both of us a call. Honesty up front.
      </p>
    </div>
    <div class="grid gap-5 md:grid-cols-2">
      <NeoCard tone="green" shadow="md" tilt={-0.4} class="space-y-3">
        <div class="flex items-center gap-3">
          <span
            class="inline-flex h-10 w-10 items-center justify-center border-[2.5px] border-ink rounded-full bg-paper shadow-neo-xs"
            aria-hidden="true"
          >
            <Icon name="lucide:thumbs-up" class="h-5 w-5" />
          </span>
          <h3 class="heading text-xl uppercase">Best for</h3>
        </div>
        <ul class="space-y-2">
          {
            bestFor.map((b) => (
              <li class="flex items-start gap-2 text-sm font-medium">
                <Icon name="lucide:check" class="h-4 w-4 mt-1 shrink-0" />
                <span>{b}</span>
              </li>
            ))
          }
        </ul>
      </NeoCard>
      <NeoCard tone="red" shadow="md" tilt={0.4} class="space-y-3">
        <div class="flex items-center gap-3">
          <span
            class="inline-flex h-10 w-10 items-center justify-center border-[2.5px] border-ink rounded-full bg-paper shadow-neo-xs"
            aria-hidden="true"
          >
            <Icon name="lucide:x" class="h-5 w-5" />
          </span>
          <h3 class="heading text-xl uppercase">Not for</h3>
        </div>
        <ul class="space-y-2">
          {
            notFor.map((b) => (
              <li class="flex items-start gap-2 text-sm font-medium">
                <Icon name="lucide:slash" class="h-4 w-4 mt-1 shrink-0" />
                <span>{b}</span>
              </li>
            ))
          }
        </ul>
      </NeoCard>
    </div>
  </section>

  <HalftoneSection tone="bg" class="py-16">
    <div class="mx-auto max-w-5xl px-5">
      <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-end mb-8">
        <div class="max-w-2xl">
          <BurstBadge tone="purple" size="sm" class="mb-4">04</BurstBadge>
          <h2 class="display text-3xl md:text-4xl leading-tight">
            FAQ.
          </h2>
          <p class="mt-3 text-base md:text-lg text-ink-soft leading-snug">
            Questions clients ask before they hit send.
          </p>
        </div>
        <SpeechBubble tone="pink" tail="br" class="max-w-[280px] hidden md:inline-block">
          <span class="text-sm leading-snug font-bold">
            "Email rough scope. Reply ≤24h weekdays — every time."
          </span>
        </SpeechBubble>
      </div>
      <ul class="grid gap-4 md:grid-cols-2">
        {
          faq.map((item, i) => (
            <li>
              <details
                class="group border-[3px] border-ink rounded-[4px] bg-paper shadow-neo-md overflow-hidden"
              >
                <summary
                  class="flex items-start justify-between gap-3 p-5 cursor-pointer font-bold uppercase tracking-tight list-none [&::-webkit-details-marker]:hidden"
                >
                  <span class="flex items-start gap-3 min-w-0">
                    <span
                      class="inline-flex h-7 w-7 shrink-0 items-center justify-center border-[2px] border-ink rounded-full bg-yellow font-black text-xs mt-0.5"
                      aria-hidden="true"
                    >
                      {String(i + 1).padStart(2, "0")}
                    </span>
                    <span class="text-base md:text-lg leading-snug">
                      {item.q}
                    </span>
                  </span>
                  <span
                    class="inline-flex h-8 w-8 shrink-0 items-center justify-center border-[2.5px] border-ink rounded-full bg-bg transition-transform group-open:rotate-45"
                    aria-hidden="true"
                  >
                    <Icon name="lucide:plus" class="h-4 w-4" />
                  </span>
                </summary>
                <div class="px-5 pb-5 pt-0 border-t-[2px] border-ink/15">
                  <p class="text-sm md:text-base leading-snug pt-4 opacity-90">
                    {item.a}
                  </p>
                </div>
              </details>
            </li>
          ))
        }
      </ul>
    </div>
  </HalftoneSection>

  <section class="mx-auto max-w-5xl px-5 py-14">
    <PanelDivider shape="dots" tone="cyan" class="!my-0 mb-8" />
    <div class="grid gap-8 md:grid-cols-[1fr_auto] items-center">
      <div>
        <BurstBadge tone="green" size="sm" class="mb-4">05</BurstBadge>
        <h2 class="display text-3xl md:text-4xl leading-tight">
          Other channels.
        </h2>
        <p class="mt-3 text-base text-ink-soft leading-snug max-w-2xl">
          Email is fastest. Everything else still works.
        </p>
      </div>
      <div
        class="relative max-w-[220px] mx-auto md:mx-0"
        data-mascot="contact"
      >
        <RobotMascot tone="cyan" size={140} />
      </div>
    </div>

    <ul class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 mt-8">
      <li>
        <a
          href={`tel:${SITE.PHONE}`}
          class="group flex items-start gap-3 border-[3px] border-ink rounded-[4px] bg-paper p-4 shadow-neo-sm transition-all hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-md hover:bg-yellow"
        >
          <Icon name="lucide:phone" class="h-5 w-5 mt-0.5 shrink-0" />
          <div class="flex-1 min-w-0">
            <p
              class="mono text-[10px] font-bold uppercase tracking-widest opacity-70"
            >
              Phone / WhatsApp
            </p>
            <p class="font-bold text-sm truncate">{SITE.PHONE_DISPLAY}</p>
          </div>
        </a>
      </li>
      <li>
        <a
          href="https://linkedin.com/in/ansezz"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-3 border-[3px] border-ink rounded-[4px] bg-paper p-4 shadow-neo-sm transition-all hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-md hover:bg-yellow"
        >
          <Icon name="lucide:linkedin" class="h-5 w-5 mt-0.5 shrink-0" />
          <div class="flex-1 min-w-0">
            <p
              class="mono text-[10px] font-bold uppercase tracking-widest opacity-70"
            >
              LinkedIn
            </p>
            <p class="font-bold text-sm truncate">/in/ansezz</p>
          </div>
        </a>
      </li>
      <li>
        <a
          href="https://github.com/ansezz"
          target="_blank"
          rel="noopener noreferrer"
          class="group flex items-start gap-3 border-[3px] border-ink rounded-[4px] bg-paper p-4 shadow-neo-sm transition-all hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-md hover:bg-yellow"
        >
          <Icon name="lucide:github" class="h-5 w-5 mt-0.5 shrink-0" />
          <div class="flex-1 min-w-0">
            <p
              class="mono text-[10px] font-bold uppercase tracking-widest opacity-70"
            >
              GitHub
            </p>
            <p class="font-bold text-sm truncate">@ansezz</p>
          </div>
        </a>
      </li>
      <li>
        <a
          href={SITE.RESUME_URL}
          target="_blank"
          rel="noopener"
          class="group flex items-start gap-3 border-[3px] border-ink rounded-[4px] bg-paper p-4 shadow-neo-sm transition-all hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-md hover:bg-yellow"
        >
          <Icon name="lucide:file-text" class="h-5 w-5 mt-0.5 shrink-0" />
          <div class="flex-1 min-w-0">
            <p
              class="mono text-[10px] font-bold uppercase tracking-widest opacity-70"
            >
              Resume (PDF)
            </p>
            <p class="font-bold text-sm truncate">For procurement</p>
          </div>
        </a>
      </li>
    </ul>

    <div class="mt-8">
      <p class="mono text-xs font-bold uppercase tracking-widest text-pink-deep mb-3">
        ▸ Available for
      </p>
      <TagPillRow scrollOnMobile>
        {
          AVAILABLE_FOR.map((label, i) => (
            <li>
              <TagPill tone={tones[i % tones.length]}>{label}</TagPill>
            </li>
          ))
        }
      </TagPillRow>
    </div>
  </section>

  <HalftoneSection tone="ink" bordered class="py-14">
    <div class="mx-auto max-w-5xl px-5 text-bg">
      <div class="grid gap-6 md:grid-cols-[1fr_auto] items-center">
        <div>
          <p class="display text-2xl md:text-3xl leading-tight">
            Find me elsewhere
          </p>
          <p class="text-sm text-bg/70 mt-2">
            Same person, different rooms.
          </p>
        </div>
        <ul class="flex flex-wrap items-center gap-4">
          <li>
            <SocialButton
              href="https://github.com/ansezz"
              icon="lucide:github"
              label="GitHub"
              tone="paper"
              size="md"
            />
          </li>
          <li>
            <SocialButton
              href="https://linkedin.com/in/ansezz"
              icon="lucide:linkedin"
              label="LinkedIn"
              tone="cyan"
              size="md"
            />
          </li>
          <li>
            <SocialButton
              href={`mailto:${SITE.EMAIL}`}
              icon="lucide:mail"
              label="Email"
              tone="yellow"
              size="md"
            />
          </li>
          <li>
            <SocialButton
              href="/rss.xml"
              icon="lucide:rss"
              label="RSS"
              tone="pink"
              size="md"
            />
          </li>
        </ul>
      </div>
    </div>
  </HalftoneSection>
</Page>
