---
import { getCollection } from "astro:content";
import Page from "@/layouts/Page.astro";
import ProjectCard from "@/components/work/ProjectCard.astro";
import TagPill from "@/components/neobrutalist/TagPill.astro";
import TagPillRow from "@/components/neobrutalist/TagPillRow.astro";
import BurstBadge from "@/components/neobrutalist/BurstBadge.astro";
import HalftoneSection from "@/components/neobrutalist/HalftoneSection.astro";
import NeoButton from "@/components/neobrutalist/NeoButton.astro";
import NeoCard from "@/components/neobrutalist/NeoCard.astro";
import PanelDivider from "@/components/neobrutalist/PanelDivider.astro";
import StickyNote from "@/components/neobrutalist/StickyNote.astro";
import { Icon } from "astro-icon/components";
import {
  WORK,
  SITE,
  OTHER_SHOPIFY_STOREFRONTS,
  OTHER_SHOPIFY_APPS,
  OTHER_PLATFORMS,
} from "@/consts";

const entries = await getCollection("work");
const sorted = entries.sort(
  (a, b) =>
    Number(b.data.featured) - Number(a.data.featured) ||
    a.data.order - b.data.order,
);

type Cat = "ai" | "shopify" | "saas";

const groups: Record<
  Cat,
  {
    slug: Cat;
    label: string;
    eyebrow: string;
    icon: string;
    tone: "cyan" | "green" | "yellow";
    items: typeof sorted;
  }
> = {
  ai: {
    slug: "ai",
    label: "AI engineering",
    eyebrow: "Claude · MCP · RAG · Agentic AI",
    icon: "lucide:brain-circuit",
    tone: "cyan",
    items: [],
  },
  shopify: {
    slug: "shopify",
    label: "Shopify Plus apps & storefronts",
    eyebrow: "Public apps · Custom themes · Checkout extensions",
    icon: "lucide:shopping-bag",
    tone: "green",
    items: [],
  },
  saas: {
    slug: "saas",
    label: "SaaS platforms",
    eyebrow: "Multi-tenant Laravel · Media · Edu · Agritech",
    icon: "lucide:server",
    tone: "yellow",
    items: [],
  },
};

for (const entry of sorted) {
  const cat = entry.data.category as Cat;
  if (cat in groups) groups[cat].items.push(entry);
}

const cardTones = ["paper", "yellow", "cyan", "green", "pink", "red", "purple"] as const;
const totalCount = sorted.length;
const featuredCount = sorted.filter((e) => e.data.featured).length;

const totalLinks =
  OTHER_SHOPIFY_STOREFRONTS.length +
  OTHER_SHOPIFY_APPS.length +
  OTHER_PLATFORMS.length;
const allLinksTotal = totalCount + totalLinks;

const toneBg: Record<string, string> = {
  yellow: "bg-yellow text-ink",
  pink: "bg-pink text-ink",
  cyan: "bg-cyan text-ink",
  green: "bg-green text-ink",
  red: "bg-red text-ink",
  blue: "bg-blue text-paper",
  purple: "bg-purple text-paper",
  ink: "bg-ink text-bg",
};

const stats: {
  v: string;
  l: string;
  icon: string;
  tone: "yellow" | "pink" | "cyan" | "green" | "red" | "purple";
}[] = [
  { v: String(allLinksTotal), l: "Live projects + links", icon: "lucide:link", tone: "yellow" },
  { v: String(featuredCount), l: "Featured case studies", icon: "lucide:star", tone: "pink" },
  { v: String(groups.shopify.items.length + OTHER_SHOPIFY_STOREFRONTS.length + OTHER_SHOPIFY_APPS.length), l: "Shopify apps + storefronts", icon: "lucide:shopping-bag", tone: "green" },
  { v: String(groups.ai.items.length), l: "AI case studies", icon: "lucide:brain-circuit", tone: "purple" },
];

// Featured marquee (top 4)
const featuredEntries = sorted.filter((e) => e.data.featured).slice(0, 4);
---

<Page
  title={WORK.TITLE}
  description={WORK.DESCRIPTION}
  eyebrow="Selected work"
  heading="Things I built. Most of them are still shipping."
  intro="A slice of projects across AI engineering, Shopify Plus apps + storefronts, multi-tenant SaaS, and open source. Tech-first descriptions — pick what you need built next."
>
  <section class="mx-auto max-w-6xl px-5 pb-6">
    <div class="flex flex-wrap items-center gap-4">
      <StickyNote tone="yellow" tilt={-2} class="max-w-[320px]">
        <p class="mono text-[10px] font-bold uppercase tracking-widest mb-1">
          ▸ How to read this page
        </p>
        <p class="text-sm font-bold leading-snug">
          Featured = full case study. The rest = live links. Resume has every
          stack + outcome.
        </p>
      </StickyNote>
      <NeoButton href={SITE.RESUME_URL} variant="secondary" size="sm">
        <Icon name="lucide:download" class="h-3.5 w-3.5" />
        Resume (PDF)
      </NeoButton>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-10">
    <ul class="grid gap-4 grid-cols-2 md:grid-cols-4">
      {
        stats.map((s, i) => (
          <li>
            <NeoCard
              tone={s.tone}
              shadow="sm"
              tilt={i % 2 === 0 ? -0.3 : 0.3}
              class="text-center flex flex-col gap-2 !p-4"
            >
              <span
                class="inline-flex h-10 w-10 mx-auto items-center justify-center border-[2.5px] border-ink rounded-full bg-paper text-ink shadow-neo-xs"
                aria-hidden="true"
              >
                <Icon name={s.icon} class="h-5 w-5" />
              </span>
              <p class="display text-4xl md:text-5xl leading-none">{s.v}</p>
              <p class="mono text-[10px] font-bold uppercase tracking-widest opacity-80">
                {s.l}
              </p>
            </NeoCard>
          </li>
        ))
      }
    </ul>
  </section>

  <div class="mx-auto max-w-6xl px-5 pb-16 space-y-14" data-work-root>
    <section>
      <div class="flex items-end justify-between gap-4 flex-wrap mb-6">
        <div>
          <BurstBadge tone="cyan" size="sm" class="mb-4">01</BurstBadge>
          <h2 class="display text-2xl md:text-3xl leading-tight">
            Filter by lane.
          </h2>
          <p class="mono text-[11px] font-bold uppercase tracking-widest opacity-60 mt-2">
            ▸ {totalCount} case studies · {featuredCount} featured
          </p>
        </div>
      </div>
      <TagPillRow scrollOnMobile>
        <li>
          <button
            type="button"
            data-work-filter="all"
            aria-pressed="true"
            class="work-filter-btn"
          >
            <TagPill tone="ink" size="md">All · {totalCount}</TagPill>
          </button>
        </li>
        {
          Object.values(groups).map(
            (g) =>
              g.items.length > 0 && (
                <li>
                  <button
                    type="button"
                    data-work-filter={g.slug}
                    aria-pressed="false"
                    class="work-filter-btn"
                  >
                    <TagPill tone={g.tone} size="md">
                      {g.label} · {g.items.length}
                    </TagPill>
                  </button>
                </li>
              ),
          )
        }
      </TagPillRow>
    </section>

    {
      featuredEntries.length > 0 && (
        <section data-work-section="all-featured" class="scroll-mt-24">
          <div class="mb-6">
            <BurstBadge tone="pink" size="sm" class="mb-4">02</BurstBadge>
            <h2 class="display text-2xl md:text-3xl leading-tight">
              Featured case studies.
            </h2>
            <p class="mono text-[11px] font-bold uppercase tracking-widest opacity-60 mt-2">
              ▸ The ones with the highest signal
            </p>
          </div>
          <ul class="grid gap-6 md:grid-cols-2">
            {featuredEntries.map((entry, i) => (
              <li>
                <ProjectCard
                  entry={entry}
                  tone={cardTones[i % cardTones.length]}
                />
              </li>
            ))}
          </ul>
        </section>
      )
    }

    <PanelDivider shape="zigzag" tone="yellow" />

    {
      Object.values(groups).map(
        (group, gi) =>
          group.items.length > 0 && (
            <section
              data-work-section={group.slug}
              id={`work-${group.slug}`}
              class="scroll-mt-24"
            >
              <div class="flex items-end gap-4 mb-6 flex-wrap">
                <BurstBadge tone={group.tone} size="sm">
                  {String(gi + 3).padStart(2, "0")}
                </BurstBadge>
                <div class="flex items-center gap-3 flex-1 min-w-0">
                  <span
                    class={`inline-flex h-12 w-12 shrink-0 items-center justify-center border-[2.5px] border-ink rounded-[6px] shadow-neo-xs ${toneBg[group.tone]}`}
                    aria-hidden="true"
                  >
                    <Icon name={group.icon} class="h-5 w-5" />
                  </span>
                  <div class="flex-1 min-w-0">
                    <h2 class="display text-2xl md:text-3xl leading-tight">
                      {group.label}
                    </h2>
                    <p class="mono text-[11px] font-bold uppercase tracking-widest opacity-60 mt-1">
                      ▸ {group.eyebrow}
                    </p>
                  </div>
                  <span
                    class="hidden md:inline-flex h-9 w-9 items-center justify-center border-[2px] border-ink rounded-full bg-ink text-bg font-black text-xs"
                    aria-hidden="true"
                  >
                    {group.items.length}
                  </span>
                </div>
              </div>
              <ul class="grid gap-6 md:grid-cols-2">
                {group.items.map((entry, i) => (
                  <li>
                    <ProjectCard
                      entry={entry}
                      tone={cardTones[(gi * 2 + i) % cardTones.length]}
                    />
                  </li>
                ))}
              </ul>
            </section>
          ),
      )
    }

    {
      sorted.length === 0 && (
        <div class="border-[3px] border-dashed border-ink rounded-[4px] p-12 text-center">
          <p class="display text-3xl mb-3">Coming soon</p>
          <p class="opacity-70">
            Case studies in progress. Drop me a line if you'd like an early look.
          </p>
        </div>
      )
    }

    <PanelDivider shape="bolt" tone="cyan" />

    <section class="space-y-10">
      <header>
        <BurstBadge tone="pink" size="sm" class="mb-4">+</BurstBadge>
        <h2 class="display text-2xl md:text-3xl leading-tight">
          More live links.
        </h2>
        <p class="mono text-[11px] font-bold uppercase tracking-widest opacity-60 mt-2">
          ▸ {totalLinks} more sites in production · short notes only
        </p>
      </header>

      <div class="space-y-10">
        <div>
          <h3 class="heading text-xl uppercase mb-4 flex items-center gap-3">
            <span
              class="inline-flex h-9 w-9 items-center justify-center border-[2.5px] border-ink rounded-full bg-green text-ink shadow-neo-xs"
              aria-hidden="true"
            >
              <Icon name="lucide:shopping-bag" class="h-4 w-4" />
            </span>
            Shopify Plus storefronts
            <span class="mono text-[10px] font-bold uppercase tracking-widest opacity-60">
              · {OTHER_SHOPIFY_STOREFRONTS.length}
            </span>
          </h3>
          <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {
              OTHER_SHOPIFY_STOREFRONTS.map((p) => (
                <li>
                  <a
                    href={p.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-start gap-3 border-[2.5px] border-ink rounded-[4px] bg-paper p-3 shadow-neo-xs transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-neo-sm hover:bg-yellow"
                  >
                    <span
                      class:list={[
                        "inline-flex h-9 w-9 shrink-0 items-center justify-center border-[2px] border-ink rounded-full font-black text-xs",
                        toneBg[p.tone],
                      ]}
                    >
                      {p.name.slice(0, 1)}
                    </span>
                    <span class="flex-1 min-w-0">
                      <span class="block font-bold text-sm truncate">
                        {p.name}
                        <span class="inline-block align-middle ml-1 opacity-60">
                          ↗
                        </span>
                      </span>
                      <span class="block mono text-[10px] uppercase tracking-widest opacity-70 truncate">
                        {p.note}
                      </span>
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h3 class="heading text-xl uppercase mb-4 flex items-center gap-3">
            <span
              class="inline-flex h-9 w-9 items-center justify-center border-[2.5px] border-ink rounded-full bg-red text-ink shadow-neo-xs"
              aria-hidden="true"
            >
              <Icon name="lucide:puzzle" class="h-4 w-4" />
            </span>
            More Shopify apps + partner pages
          </h3>
          <ul class="grid gap-3 sm:grid-cols-2">
            {
              OTHER_SHOPIFY_APPS.map((p) => (
                <li>
                  <a
                    href={p.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-start gap-3 border-[2.5px] border-ink rounded-[4px] bg-paper p-3 shadow-neo-xs transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-neo-sm hover:bg-yellow"
                  >
                    <span
                      class:list={[
                        "inline-flex h-9 w-9 shrink-0 items-center justify-center border-[2px] border-ink rounded-full font-black text-xs",
                        toneBg[p.tone],
                      ]}
                    >
                      {p.name.slice(0, 1)}
                    </span>
                    <span class="flex-1 min-w-0">
                      <span class="block font-bold text-sm truncate">
                        {p.name}
                        <span class="inline-block align-middle ml-1 opacity-60">
                          ↗
                        </span>
                      </span>
                      <span class="block mono text-[10px] uppercase tracking-widest opacity-70 truncate">
                        {p.note}
                      </span>
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div>
          <h3 class="heading text-xl uppercase mb-4 flex items-center gap-3">
            <span
              class="inline-flex h-9 w-9 items-center justify-center border-[2.5px] border-ink rounded-full bg-blue text-paper shadow-neo-xs"
              aria-hidden="true"
            >
              <Icon name="lucide:globe" class="h-4 w-4" />
            </span>
            Other platforms + profiles
            <span class="mono text-[10px] font-bold uppercase tracking-widest opacity-60">
              · {OTHER_PLATFORMS.length}
            </span>
          </h3>
          <ul class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
            {
              OTHER_PLATFORMS.map((p) => (
                <li>
                  <a
                    href={p.url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group flex items-start gap-3 border-[2.5px] border-ink rounded-[4px] bg-paper p-3 shadow-neo-xs transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-neo-sm hover:bg-yellow"
                  >
                    <span
                      class:list={[
                        "inline-flex h-9 w-9 shrink-0 items-center justify-center border-[2px] border-ink rounded-full font-black text-xs",
                        toneBg[p.tone],
                      ]}
                    >
                      {p.name.slice(0, 1)}
                    </span>
                    <span class="flex-1 min-w-0">
                      <span class="block font-bold text-sm truncate">
                        {p.name}
                        <span class="inline-block align-middle ml-1 opacity-60">
                          ↗
                        </span>
                      </span>
                      <span class="block mono text-[10px] uppercase tracking-widest opacity-70 truncate">
                        {p.note}
                      </span>
                    </span>
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </section>

    <NeoCard tone="paper" class="text-center space-y-4">
      <p class="mono text-xs font-bold uppercase tracking-widest text-pink-deep">
        ▸ Need the boring version?
      </p>
      <p class="text-base md:text-lg max-w-2xl mx-auto leading-snug">
        Resume has every role, stack, and outcome — including projects under
        NDA that aren't listed here.
      </p>
      <div class="flex flex-wrap items-center justify-center gap-3 pt-2">
        <NeoButton
          href={SITE.RESUME_URL}
          variant="primary"
          size="lg"
          ariaLabel="Download resume PDF"
        >
          <Icon name="lucide:download" class="h-4 w-4" />
          Download resume (PDF)
        </NeoButton>
        <NeoButton href="/contact/" variant="ink" size="lg">
          <Icon name="lucide:mail" class="h-4 w-4" />
          Start a project →
        </NeoButton>
      </div>
    </NeoCard>
  </div>

  <HalftoneSection tone="blue" bordered class="py-14 text-paper">
    <div class="mx-auto max-w-5xl px-5 grid gap-6 md:grid-cols-[1fr_auto] items-center">
      <div>
        <p class="display text-3xl md:text-4xl leading-tight">
          Got a project that needs a senior engineer who actually ships?
        </p>
        <p class="mt-3 text-base text-paper/80">
          Discovery call is free. I'll tell you honestly if it's a fit.
        </p>
      </div>
      <NeoButton href="/contact/" variant="primary" size="lg">
        Start a project →
      </NeoButton>
    </div>
  </HalftoneSection>
</Page>

<style>
  .work-filter-btn {
    appearance: none;
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
  }
  .work-filter-btn[aria-pressed="true"] :global(span) {
    box-shadow: var(--shadow-neo-sm);
    transform: translate(-2px, -2px);
  }
</style>

<script>
  const root = document.querySelector<HTMLElement>("[data-work-root]");
  if (root) {
    const buttons =
      root.querySelectorAll<HTMLButtonElement>("[data-work-filter]");
    const sections =
      root.querySelectorAll<HTMLElement>("[data-work-section]");

    function setFilter(value: string) {
      buttons.forEach((btn) => {
        const pressed = btn.dataset.workFilter === value;
        btn.setAttribute("aria-pressed", pressed ? "true" : "false");
      });
      sections.forEach((section) => {
        const slug = section.dataset.workSection;
        if (value === "all") {
          section.hidden = slug === "all-featured" ? false : false;
        } else {
          section.hidden = slug !== value;
        }
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const value = btn.dataset.workFilter ?? "all";
        setFilter(value);
      });
    });
  }
</script>
