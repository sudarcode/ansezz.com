---
import Page from "@/layouts/Page.astro";
import NeoCard from "@/components/neobrutalist/NeoCard.astro";
import StickyNote from "@/components/neobrutalist/StickyNote.astro";
import { SITE } from "@/consts";
import { breadcrumbList } from "@/lib/seo";

const breadcrumbLd = breadcrumbList([
  { name: "Home", url: SITE.URL },
  { name: "Tools", url: "/tools/" },
  { name: "Cron Explainer", url: "/tools/cron-explainer/" },
]);

const presets = [
  { label: "Every 5 min", expr: "*/5 * * * *" },
  { label: "Hourly", expr: "0 * * * *" },
  { label: "Daily 2am", expr: "0 2 * * *" },
  { label: "Mon 9am", expr: "0 9 * * 1" },
  { label: "1st of month", expr: "0 0 1 * *" },
  { label: "Weekdays noon", expr: "0 12 * * 1-5" },
];
---

<Page
  title="Cron Explainer"
  description="Free cron expression explainer. Paste a 5-field cron schedule and read what it does in plain English, field by field. Runs entirely in your browser."
  eyebrow="Free tool"
  heading="Cron Explainer."
  intro="Paste a 5-field cron expression — get a plain-English description of exactly when it fires. Built it for my own schedulers."
  structuredData={breadcrumbLd}
>
  <section class="mx-auto max-w-3xl px-5 pb-6">
    <StickyNote tone="yellow" tilt={-1.5} class="max-w-md">
      <p class="mono text-[10px] font-bold uppercase tracking-widest mb-1">
        ▸ Format
      </p>
      <p class="text-sm font-bold leading-snug">
        Standard 5 fields: minute hour day-of-month month day-of-week.
        Supports <code>*</code>, <code>*/n</code>, ranges <code>a-b</code>, and
        lists <code>a,b,c</code>.
      </p>
    </StickyNote>
  </section>

  <section class="mx-auto max-w-3xl px-5 pb-16" id="cron-root">
    <NeoCard tone="paper" shadow="md" class="space-y-4">
      <label
        for="cron-input"
        class="mono text-[11px] font-bold uppercase tracking-widest block"
      >
        Cron expression
      </label>
      <input
        id="cron-input"
        type="text"
        value="0 2 * * *"
        spellcheck="false"
        autocomplete="off"
        class="w-full border-[3px] border-ink rounded-[4px] bg-paper px-4 py-3.5 font-mono text-lg font-bold shadow-neo-sm focus:outline-none"
      />
      <div class="flex flex-wrap gap-2">
        {
          presets.map((p) => (
            <button
              type="button"
              data-cron-preset={p.expr}
              class="border-[2px] border-ink rounded-full bg-bg-alt px-3 py-1 mono text-[10px] font-bold uppercase tracking-widest shadow-neo-xs transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:bg-yellow hover:shadow-neo-sm"
            >
              {p.label}
            </button>
          ))
        }
      </div>
    </NeoCard>

    <NeoCard tone="cyan" shadow="lg" class="mt-6 space-y-3">
      <p class="mono text-[11px] font-bold uppercase tracking-widest">
        ▸ In plain English
      </p>
      <p id="cron-summary" class="text-lg md:text-xl font-bold leading-snug">
        —
      </p>
      <ul id="cron-fields" class="space-y-1.5 border-t-[2.5px] border-ink pt-3 text-sm"></ul>
    </NeoCard>
  </section>
</Page>

<script>
  import "@/scripts/cron-explainer";
</script>
