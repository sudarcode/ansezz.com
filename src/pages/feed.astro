---
import Page from "@/layouts/Page.astro";
import NeoCard from "@/components/neobrutalist/NeoCard.astro";
import HalftoneSection from "@/components/neobrutalist/HalftoneSection.astro";
import { Icon } from "astro-icon/components";
import { SITE, X_HANDLE } from "@/consts";

const xProfile = `https://x.com/${X_HANDLE}`;
---

<Page
  title="Social feed"
  description={`Live X timeline from ${SITE.SHORT_TITLE} — engineering notes, hot takes, shipping logs.`}
  eyebrow="Social"
  heading="Live feed."
  intro="Real-time X timeline — production logs, shipping notes, contrarian takes on Laravel + Shopify + AI."
>
  <div class="mx-auto max-w-3xl px-5 pb-20">
    <div class="flex flex-wrap items-center gap-3 mb-10">
      <a
        href={xProfile}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full border-[2.5px] border-ink bg-ink text-paper shadow-neo-xs hover:-translate-y-0.5 hover:shadow-neo-sm hover:bg-paper hover:text-ink transition-all text-sm font-bold"
      >
        <Icon name="lucide:twitter" class="h-4 w-4" />
        @{X_HANDLE} on X
      </a>
      <a
        href="/rss.xml"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-full border-[2.5px] border-ink bg-pink text-paper shadow-neo-xs hover:-translate-y-0.5 hover:shadow-neo-sm transition-all text-sm font-bold"
      >
        <Icon name="lucide:rss" class="h-4 w-4" />
        Blog RSS
      </a>
    </div>

    <section id="x-feed">
      <div class="flex items-end justify-between gap-4 mb-5">
        <div>
          <p class="mono text-[10px] font-bold uppercase tracking-[0.2em] opacity-60">
            ▸ Real-time
          </p>
          <h2 class="display text-2xl md:text-3xl mt-2 flex items-center gap-3">
            <Icon name="lucide:twitter" class="h-6 w-6" />
            X timeline
          </h2>
        </div>
        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full border-[2.5px] border-ink bg-green shadow-neo-xs mono text-[10px] font-bold uppercase tracking-widest">
          <span class="relative inline-flex h-2 w-2">
            <span class="absolute inline-flex h-full w-full rounded-full bg-ink opacity-75 animate-ping"></span>
            <span class="relative inline-flex h-2 w-2 rounded-full bg-ink"></span>
          </span>
          Live
        </span>
      </div>

      <NeoCard tone="paper" class="p-3 md:p-4">
        <div data-x-timeline>
          <a
            class="twitter-timeline"
            data-theme="light"
            data-chrome="noheader nofooter noborders transparent"
            data-tweet-limit="10"
            data-dnt="true"
            href={`https://twitter.com/${X_HANDLE}`}
          >
            Loading @{X_HANDLE} on X…
          </a>
        </div>
        <noscript>
          <p class="text-sm opacity-70 px-3 py-6 text-center">
            Enable JavaScript to load the X timeline, or
            <a href={xProfile} class="underline hover:bg-yellow">visit @{X_HANDLE} on X</a>.
          </p>
        </noscript>
      </NeoCard>
    </section>

    <HalftoneSection tone="bg" class="mt-16 py-8 -mx-5 px-5 border-y-[3px] border-ink">
      <div class="mx-auto max-w-3xl text-center">
        <p class="mono text-[10px] font-bold uppercase tracking-[0.2em] opacity-60 mb-3">
          ▸ Prefer the long form?
        </p>
        <p class="text-base md:text-lg leading-snug">
          Bite-sized takes here. Full essays —{" "}
          <a href="/blog/" class="underline decoration-[3px] decoration-pink underline-offset-4 hover:bg-yellow">
            on the blog
          </a>.
        </p>
      </div>
    </HalftoneSection>
  </div>
</Page>

<script
  is:inline
  async
  src="https://platform.twitter.com/widgets.js"
  charset="utf-8"
></script>
