---
import { getCollection } from "astro:content";
import Page from "@/layouts/Page.astro";
import NeoCard from "@/components/neobrutalist/NeoCard.astro";
import NeoButton from "@/components/neobrutalist/NeoButton.astro";
import BurstBadge from "@/components/neobrutalist/BurstBadge.astro";
import ChecklistBox from "@/components/neobrutalist/ChecklistBox.astro";
import { Icon } from "astro-icon/components";
import { NEWSLETTER, SITE, CATEGORY_LABEL } from "@/consts";
import { breadcrumbList } from "@/lib/seo";

const breadcrumbLd = breadcrumbList([
  { name: "Home", url: SITE.URL },
  { name: "Newsletter", url: "/newsletter/" },
]);

const recent = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 5);

const promises = [
  { label: "One short email per new post", done: true },
  { label: "Laravel, AI engineering, Shopify, DevOps", done: true },
  { label: "No drip funnels, no upsells", done: true },
  { label: "Unsubscribe in one click, anytime", done: true },
];
---

<Page
  title={NEWSLETTER.TITLE}
  description={NEWSLETTER.DESCRIPTION}
  eyebrow="Newsletter"
  heading="The no-fluff list."
  intro={NEWSLETTER.DESCRIPTION}
  structuredData={breadcrumbLd}
>
  <section class="mx-auto max-w-5xl px-5 pb-12">
    <div class="grid gap-6 md:grid-cols-2">
      <!-- Subscribe -->
      <NeoCard tone="yellow" shadow="lg" class="flex flex-col gap-5">
        <div>
          <BurstBadge tone="pink" size="sm" class="mb-3">@</BurstBadge>
          <h2 class="display text-2xl md:text-3xl leading-[0.95]">
            Subscribe
          </h2>
        </div>
        <form
          method="post"
          action={NEWSLETTER.SUBSCRIBE_ACTION}
          target="_blank"
          class="flex flex-col gap-3"
        >
          <label class="block">
            <span class="sr-only">Email address</span>
            <div class="relative">
              <Icon
                name="lucide:mail"
                class="absolute left-3 top-1/2 -translate-y-1/2 h-5 w-5 pointer-events-none"
              />
              <input
                type="email"
                name="email"
                required
                placeholder="you@domain.com"
                autocomplete="email"
                class="w-full border-[3px] border-ink rounded-[4px] bg-paper pl-10 pr-4 py-3.5 text-base font-medium shadow-neo-md placeholder:text-ink/40 focus:outline-none focus:translate-x-[-2px] focus:translate-y-[-2px] focus:shadow-neo-lg transition-all"
              />
            </div>
          </label>
          <input type="hidden" name="embed" value="1" />
          <NeoButton type="submit" variant="ink" size="lg" fullWidth>
            Subscribe →
          </NeoButton>
        </form>
      </NeoCard>

      <!-- What you get -->
      <div class="flex flex-col gap-5">
        <ChecklistBox title="What you get" items={promises} tone="cyan" />
        <NeoCard tone="paper" shadow="sm" class="space-y-3">
          <p class="mono text-[10px] font-bold uppercase tracking-widest text-pink-deep">
            ▸ Past issues
          </p>
          <p class="text-sm leading-snug">
            Read everything I've sent before you commit your inbox.
          </p>
          <NeoButton
            href={NEWSLETTER.ARCHIVE_URL}
            variant="secondary"
            size="sm"
          >
            <Icon name="lucide:archive" class="h-3.5 w-3.5" />
            Browse the archive
          </NeoButton>
        </NeoCard>
      </div>
    </div>
  </section>

  <!-- Recent posts -->
  <section class="mx-auto max-w-5xl px-5 pb-16">
    <p class="mono text-xs font-bold uppercase tracking-widest opacity-60 mb-5">
      ▸ Recently on the blog
    </p>
    <ul class="space-y-3">
      {
        recent.map((p) => (
          <li>
            <a
              href={`/blog/${p.id}/`}
              data-neo-hover
              class="group flex items-center gap-4 border-[3px] border-ink rounded-[4px] bg-paper p-4 shadow-neo-sm transition-all hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-md hover:bg-yellow"
            >
              <span class="mono text-[10px] font-bold uppercase tracking-widest opacity-60 shrink-0 w-24">
                {CATEGORY_LABEL[p.data.category]}
              </span>
              <span class="heading text-base md:text-lg uppercase leading-tight flex-1 min-w-0">
                {p.data.title}
              </span>
              <Icon
                name="lucide:arrow-right"
                class="h-5 w-5 shrink-0 opacity-50 group-hover:opacity-100"
              />
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</Page>
