---
import { getCollection } from "astro:content";
import Page from "@/layouts/Page.astro";
import PostCard from "@/components/blog/PostCard.astro";
import TagPill from "@/components/neobrutalist/TagPill.astro";
import {
  BLOG_CATEGORIES,
  CATEGORY_LABEL,
  CATEGORY_TONE,
  type BlogCategory,
  SITE,
} from "@/consts";

export async function getStaticPaths() {
  return BLOG_CATEGORIES.map((category) => ({
    params: { category },
    props: { category },
  }));
}

type Props = { category: BlogCategory };
const { category } = Astro.props as Props;
const label = CATEGORY_LABEL[category];

const all = (await getCollection("blog", ({ data }) => !data.draft))
  .filter((p) => p.data.category === category)
  .sort(
    (a, b) =>
      Number(b.data.featured) - Number(a.data.featured) ||
      b.data.publishDate.getTime() - a.data.publishDate.getTime(),
  );

const tones = ["paper", "yellow", "cyan", "green", "pink", "red", "purple"] as const;

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE.URL },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: new URL("/blog/", SITE.URL).href,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: label,
      item: new URL(`/blog/category/${category}/`, SITE.URL).href,
    },
  ],
};
---

<Page
  title={`${label} posts`}
  description={`Articles in the ${label} category — ${all.length} ${all.length === 1 ? "post" : "posts"}.`}
  eyebrow={`Category · ${label}`}
  heading={`Notes on ${label}.`}
  intro={`${all.length} ${all.length === 1 ? "post" : "posts"} in this category.`}
  image={`/og/category/${category}.png`}
  structuredData={breadcrumbLd}
>
  <div class="mx-auto max-w-4xl px-5 pb-16 space-y-10">
    <div>
      <p
        class="mono text-xs font-bold uppercase tracking-widest opacity-60 mb-3"
      >
        Browse other categories
      </p>
      <ul class="flex flex-wrap gap-2">
        <li><TagPill tone="ink" href="/blog/">All</TagPill></li>
        {
          BLOG_CATEGORIES.map((c) => (
            <li>
              <TagPill
                tone={CATEGORY_TONE[c]}
                href={`/blog/category/${c}/`}
                active={c === category}
              >
                {CATEGORY_LABEL[c]}
              </TagPill>
            </li>
          ))
        }
      </ul>
    </div>

    {
      all.length > 0 ? (
        <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {all.map((post, i) => (
            <li>
              <PostCard
                post={post}
                eager={i < 3}
                tone={tones[i % tones.length]}
              />
            </li>
          ))}
        </ul>
      ) : (
        <div class="border-[3px] border-dashed border-ink rounded-[4px] p-12 text-center">
          <p class="display text-3xl mb-2">Nothing here yet</p>
          <p class="opacity-70">
            No posts in {label} yet. Check back soon.
          </p>
        </div>
      )
    }
  </div>
</Page>
