---
import type { GetStaticPaths, Page } from "astro";
import { getCollection } from "astro:content";
import type { CollectionEntry } from "astro:content";
import PageLayout from "@/layouts/Page.astro";
import PostCard from "@/components/blog/PostCard.astro";
import TagPill from "@/components/neobrutalist/TagPill.astro";
import TagPillRow from "@/components/neobrutalist/TagPillRow.astro";
import NeoButton from "@/components/neobrutalist/NeoButton.astro";
import HalftoneSection from "@/components/neobrutalist/HalftoneSection.astro";
import NewsletterCallout from "@/components/home/NewsletterCallout.astro";
import { BLOG, BLOG_CATEGORIES, CATEGORY_LABEL, CATEGORY_TONE } from "@/consts";

export const getStaticPaths = (async ({ paginate }) => {
  const all = (await getCollection("blog", ({ data }) => !data.draft)).sort(
    (a, b) =>
      Number(b.data.featured) - Number(a.data.featured) ||
      b.data.publishDate.getTime() - a.data.publishDate.getTime(),
  );
  const [, ...rest] = all;
  const pages = paginate(rest, { pageSize: 9 });
  return pages.filter((p) => String(p.params.page) !== "1");
}) satisfies GetStaticPaths;

interface Props {
  page: Page<CollectionEntry<"blog">>;
}

const { page } = Astro.props;
const prevUrl = page.currentPage === 2 ? "/blog/" : page.url.prev;
---

<PageLayout
  title={`${BLOG.TITLE} · Page ${page.currentPage}`}
  description={BLOG.DESCRIPTION}
  eyebrow={`Blog · Page ${page.currentPage}`}
  heading="More from the trenches."
  intro="Older posts. Same hot takes."
  prev={prevUrl}
  next={page.url.next}
>
  <HalftoneSection tone="bg" class="pb-2">
    <div class="mx-auto max-w-6xl px-5">
      <TagPillRow scrollOnMobile sticky class="!top-[60px] md:!top-[64px]">
        <li><TagPill tone="ink" href="/blog/">All</TagPill></li>
        {
          BLOG_CATEGORIES.map((c) => (
            <li>
              <TagPill tone={CATEGORY_TONE[c]} href={`/blog/category/${c}/`}>
                {CATEGORY_LABEL[c]}
              </TagPill>
            </li>
          ))
        }
      </TagPillRow>
    </div>
  </HalftoneSection>

  <div class="mx-auto max-w-6xl px-5 pb-16 space-y-12 pt-10">
    <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {page.data.map((post) => (
        <li>
          <PostCard post={post} />
        </li>
      ))}
    </ul>

    <nav
      class="flex items-center justify-between gap-4 flex-wrap"
      aria-label="Blog pagination"
    >
      {
        prevUrl ? (
          <NeoButton href={prevUrl} variant="primary" size="md">
            ← Newer
          </NeoButton>
        ) : (
          <NeoButton variant="secondary" size="md" disabled>
            ← Newer
          </NeoButton>
        )
      }
      <p class="mono text-xs font-bold uppercase tracking-widest opacity-70">
        Page {page.currentPage} · {page.lastPage} total
      </p>
      {
        page.url.next ? (
          <NeoButton href={page.url.next} variant="primary" size="md">
            Older →
          </NeoButton>
        ) : (
          <NeoButton variant="secondary" size="md" disabled>
            Older →
          </NeoButton>
        )
      }
    </nav>
  </div>

  <NewsletterCallout />
</PageLayout>
