---
import { getCollection } from "astro:content";
import Page from "@/layouts/Page.astro";
import NeoCard from "@/components/neobrutalist/NeoCard.astro";
import NeoButton from "@/components/neobrutalist/NeoButton.astro";
import PostMeta from "@/components/blog/PostMeta.astro";
import { Icon } from "astro-icon/components";
import { getReadingTime } from "@/lib/reading";
import { BLOG_SERIES, SITE } from "@/consts";
import { breadcrumbList } from "@/lib/seo";

export async function getStaticPaths() {
  const all = await getCollection("blog", ({ data }) => !data.draft);
  const byId = new Map(all.map((p) => [p.id, p]));
  return BLOG_SERIES.map((series) => ({
    params: { series: series.slug },
    props: {
      series,
      entries: series.posts.map((id) => byId.get(id)).filter(Boolean),
    },
  }));
}

const { series, entries } = Astro.props;

const seriesUrl = `/blog/series/${series.slug}/`;
const breadcrumbLd = breadcrumbList([
  { name: "Home", url: SITE.URL },
  { name: "Blog", url: "/blog/" },
  { name: "Series", url: "/blog/series/" },
  { name: series.title, url: seriesUrl },
]);
const itemListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: series.title,
  description: series.description,
  itemListElement: entries.map((e: any, i: number) => ({
    "@type": "ListItem",
    position: i + 1,
    url: new URL(`/blog/${e.id}/`, SITE.URL).href,
    name: e.data.title,
  })),
};
---

<Page
  title={`${series.title} — series`}
  description={series.description}
  eyebrow="Blog series"
  heading={series.title}
  intro={series.description}
  structuredData={[breadcrumbLd, itemListLd]}
>
  <section class="mx-auto max-w-4xl px-5 pb-6">
    <NeoButton href="/blog/series/" variant="secondary" size="sm">
      ← All series
    </NeoButton>
  </section>

  <section class="mx-auto max-w-4xl px-5 pb-16">
    <ol class="space-y-5">
      {
        entries.map((entry: any, i: number) => (
          <li>
            <a href={`/blog/${entry.id}/`} class="block" data-neo-hover>
              <NeoCard
                tone={i === 0 ? series.tone : "paper"}
                shadow="sm"
                class="flex gap-4 items-start transition-all hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-md"
              >
                <span class="display text-3xl md:text-4xl leading-none shrink-0 opacity-50">
                  {String(i + 1).padStart(2, "0")}
                </span>
                <div class="flex-1 min-w-0">
                  <h2 class="heading text-lg md:text-xl uppercase leading-tight">
                    {entry.data.title}
                  </h2>
                  <p class="text-sm leading-snug opacity-90 mt-1.5">
                    {entry.data.description}
                  </p>
                  <div class="mt-3">
                    <PostMeta
                      date={entry.data.publishDate}
                      updatedDate={entry.data.updatedDate}
                      category={entry.data.category}
                      readingTime={getReadingTime(entry.body)}
                      linkCategory={false}
                    />
                  </div>
                </div>
                <Icon
                  name="lucide:arrow-right"
                  class="h-5 w-5 shrink-0 mt-1 opacity-50"
                />
              </NeoCard>
            </a>
          </li>
        ))
      }
    </ol>
  </section>
</Page>
