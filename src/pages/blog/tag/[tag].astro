---
import { getCollection } from "astro:content";
import Page from "@/layouts/Page.astro";
import PostCard from "@/components/blog/PostCard.astro";
import { SITE, CARD_TONES } from "@/consts";
import { breadcrumbList } from "@/lib/seo";
import { tagSlug } from "@/lib/links";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  const tagMap = new Map<string, string>();
  for (const post of posts) {
    for (const tag of post.data.tags) {
      const slug = tagSlug(tag);
      if (!tagMap.has(slug)) tagMap.set(slug, tag);
    }
  }
  return [...tagMap.entries()].map(([slug, display]) => ({
    params: { tag: slug },
    props: { tag: display, slug },
  }));
}

type Props = { tag: string; slug: string };
const { tag, slug } = Astro.props as Props;

const all = (await getCollection("blog", ({ data }) => !data.draft))
  .filter((p) => p.data.tags.some((t) => tagSlug(t) === slug))
  .sort(
    (a, b) =>
      Number(b.data.featured) - Number(a.data.featured) ||
      b.data.publishDate.getTime() - a.data.publishDate.getTime(),
  );

const label = `#${tag}`;
const breadcrumbLd = breadcrumbList([
  { name: "Home", url: SITE.URL },
  { name: "Blog", url: "/blog/" },
  { name: label, url: `/blog/tag/${slug}/` },
]);

const tones = CARD_TONES;
---

<Page
  title={`Posts tagged ${label}`}
  description={`${all.length} ${all.length === 1 ? "post" : "posts"} tagged with ${label}.`}
  eyebrow={`Tag · ${label}`}
  heading={`Posts tagged ${label}.`}
  intro={`${all.length} ${all.length === 1 ? "post" : "posts"} with this tag.`}
  image={`/og/tag/${slug}.png`}
  structuredData={breadcrumbLd}
>
  <div class="mx-auto max-w-4xl px-5 pb-16 space-y-10">
    <p>
      <a
        href="/blog/"
        class="mono text-xs font-bold uppercase tracking-widest text-pink-deep hover:bg-yellow hover:text-ink px-1 -mx-1"
      >
        ← Back to all posts
      </a>
    </p>

    {
      all.length > 0 ? (
        <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {all.map((post, i) => (
            <li>
              <PostCard
                post={post}
                eager={i < 3}
                tone={tones[i % tones.length]}
              />
            </li>
          ))}
        </ul>
      ) : (
        <div class="border-[3px] border-dashed border-ink rounded-[4px] p-12 text-center">
          <p class="display text-3xl mb-2">Nothing here yet</p>
          <p class="opacity-70">No posts with {label}.</p>
        </div>
      )
    }
  </div>
</Page>
