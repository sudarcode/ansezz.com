---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import PostMeta from "@/components/blog/PostMeta.astro";
import RelatedPosts from "@/components/blog/RelatedPosts.astro";
import NeoCard from "@/components/neobrutalist/NeoCard.astro";
import TagPill from "@/components/neobrutalist/TagPill.astro";
import RobotMascot from "@/components/neobrutalist/RobotMascot.astro";
import { getReadingTime, getWordCount } from "@/lib/reading";
import { tagSlug } from "@/lib/links";
import { OWNER, SITE, CATEGORY_LABEL } from "@/consts";
import { webPage } from "@/lib/seo";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const rt = getReadingTime(post.body, post);
const words = getWordCount(post.body, post);

const all = await getCollection("blog", ({ data }) => !data.draft);
const related = all
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .slice(0, 3);

const canonicalUrl = new URL(`/blog/${post.id}/`, SITE.URL).href;
const heroUrl = post.data.heroImage?.url
  ? new URL(post.data.heroImage.url, SITE.URL).href
  : new URL("/og.webp", SITE.URL).href;

const webPageLd = {
  ...webPage({
    url: canonicalUrl,
    title: post.data.title,
    description: post.data.description,
    image: heroUrl,
  }),
  breadcrumb: { "@id": `${canonicalUrl}#breadcrumb` },
};

const articleLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${canonicalUrl}#article`,
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.publishDate).toISOString(),
  url: canonicalUrl,
  mainEntityOfPage: { "@id": `${canonicalUrl}#webpage` },
  image: [heroUrl],
  wordCount: words,
  timeRequired: `PT${Math.max(1, Math.round(words / 200))}M`,
  author: {
    "@type": "Person",
    "@id": `${SITE.URL}#person`,
    name: OWNER.NAME,
    url: SITE.URL,
  },
  publisher: {
    "@type": "Person",
    "@id": `${SITE.URL}#person`,
    name: OWNER.NAME,
    url: SITE.URL,
  },
  articleSection: CATEGORY_LABEL[post.data.category],
  keywords: post.data.tags.join(", "),
  inLanguage: "en",
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE.URL },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: new URL("/blog/", SITE.URL).href,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: canonicalUrl,
    },
  ],
};

const relatedLd =
  related.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "ItemList",
        name: "Related posts",
        itemListElement: related.map((p, i) => ({
          "@type": "ListItem",
          position: i + 1,
          url: new URL(`/blog/${p.id}/`, SITE.URL).href,
          name: p.data.title,
        })),
      }
    : null;

const structured = relatedLd
  ? [webPageLd, articleLd, breadcrumbLd, relatedLd]
  : [webPageLd, articleLd, breadcrumbLd];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.heroImage?.url ?? "/og.webp"}
  ogType="article"
  article={{
    publishedTime: post.data.publishDate.toISOString(),
    modifiedTime: (post.data.updatedDate ?? post.data.publishDate).toISOString(),
    author: OWNER.NAME,
    section: CATEGORY_LABEL[post.data.category],
    tags: post.data.tags,
  }}
  structuredData={structured}
>
  <section class="mx-auto max-w-5xl px-5 pt-12 pb-6 md:pt-20 md:pb-8">
    <a
      href="/blog/"
      class="mono text-xs font-bold uppercase tracking-widest text-pink-deep mb-4 inline-flex items-center gap-2 hover:bg-yellow hover:text-ink px-1 -mx-1"
    >
      ← Back to blog
    </a>
    <PostMeta
      date={post.data.publishDate}
      updatedDate={post.data.updatedDate}
      category={post.data.category}
      readingTime={rt}
    />
    <h1 class="display text-[clamp(1.875rem,5vw,3.5rem)] mt-5 max-w-5xl">
      {post.data.title}
    </h1>
    <p class="mt-5 max-w-3xl text-base sm:text-lg md:text-xl text-ink/80 leading-snug">
      {post.data.description}
    </p>
    {
      post.data.tags.length > 0 && (
        <ul class="flex flex-wrap gap-2 mt-6">
          {post.data.tags.map((t) => (
            <li>
              <TagPill tone="paper" size="sm" href={`/blog/tag/${tagSlug(t)}/`}>
                #{t}
              </TagPill>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  {
    post.data.heroImage && (
      <section class="mx-auto max-w-5xl px-5 pb-10">
        <figure class="border-[3px] border-ink shadow-neo-md overflow-hidden bg-ink mx-auto max-w-4xl aspect-[16/10]">
          <img
            src={post.data.heroImage.url}
            alt={post.data.heroImage.alt}
            width="1600"
            height="1000"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="w-full h-full object-cover"
          />
        </figure>
      </section>
    )
  }

  <section class="mx-auto max-w-5xl px-5 pb-10">
    <article class="prose mx-auto max-w-3xl">
      <Content />
    </article>
  </section>

  <section class="mx-auto max-w-5xl px-5 pb-10">
    <NeoCard
      tone="cyan"
      class="mx-auto max-w-3xl flex flex-col md:flex-row gap-5 items-center"
    >
      <RobotMascot tone="yellow" size={100} class="shrink-0" />
      <div class="text-center md:text-left">
        <p class="mono text-xs font-bold uppercase tracking-widest opacity-70">
          Written by
        </p>
        <p class="display text-2xl md:text-3xl">{OWNER.NAME}</p>
        <p class="text-sm mt-2">{OWNER.TAGLINE}</p>
        <div class="mt-3 flex flex-wrap gap-2 justify-center md:justify-start">
          <TagPill tone="paper" size="sm" href="/about/">About →</TagPill>
          <TagPill tone="ink" size="sm" href="/contact/">Hire me →</TagPill>
        </div>
      </div>
    </NeoCard>
  </section>

  <RelatedPosts posts={related} />
</BaseLayout>
