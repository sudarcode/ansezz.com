---
import { getCollection, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import RelatedPosts from "@/components/blog/RelatedPosts.astro";
import AuthorFooter from "@/components/blog/AuthorFooter.astro";
import TableOfContents from "@/components/blog/TableOfContents.astro";
import ShareBar from "@/components/blog/ShareBar.astro";
import ReadingProgress from "@/components/blog/ReadingProgress.astro";
import TagPill from "@/components/neobrutalist/TagPill.astro";
import ChecklistBox from "@/components/neobrutalist/ChecklistBox.astro";
import HalftoneSection from "@/components/neobrutalist/HalftoneSection.astro";
import PanelDivider from "@/components/neobrutalist/PanelDivider.astro";
import NeoButton from "@/components/neobrutalist/NeoButton.astro";
import NeoCard from "@/components/neobrutalist/NeoCard.astro";
import { Icon } from "astro-icon/components";
import { getReadingTime, getWordCount } from "@/lib/reading";
import { tagSlug } from "@/lib/links";
import { OWNER, SITE, CATEGORY_LABEL, CATEGORY_TONE } from "@/consts";
import { webPage } from "@/lib/seo";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const rt = getReadingTime(post.body, post);
const words = getWordCount(post.body, post);

const all = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
const currentIndex = all.findIndex((p) => p.id === post.id);
const prevPost = currentIndex > 0 ? all[currentIndex - 1] : undefined;
const nextPost =
  currentIndex >= 0 && currentIndex < all.length - 1
    ? all[currentIndex + 1]
    : undefined;
const related = all
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .slice(0, 3);

const skillsChecklist = post.data.tags.slice(0, 6).map((t) => ({
  label: t,
  done: true,
}));

const canonicalUrl = new URL(`/blog/${post.id}/`, SITE.URL).href;
const heroUrl = post.data.heroImage?.url
  ? new URL(post.data.heroImage.url, SITE.URL).href
  : new URL("/og.webp", SITE.URL).href;

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });

const webPageLd = {
  ...webPage({
    url: canonicalUrl,
    title: post.data.title,
    description: post.data.description,
    image: heroUrl,
  }),
  breadcrumb: { "@id": `${canonicalUrl}#breadcrumb` },
};

const articleLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "@id": `${canonicalUrl}#article`,
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.publishDate.toISOString(),
  dateModified: (post.data.updatedDate ?? post.data.publishDate).toISOString(),
  url: canonicalUrl,
  mainEntityOfPage: { "@id": `${canonicalUrl}#webpage` },
  image: [heroUrl],
  wordCount: words,
  timeRequired: `PT${Math.max(1, Math.round(words / 200))}M`,
  author: {
    "@type": "Person",
    "@id": `${SITE.URL}#person`,
    name: OWNER.NAME,
    url: SITE.URL,
  },
  publisher: {
    "@type": "Person",
    "@id": `${SITE.URL}#person`,
    name: OWNER.NAME,
    url: SITE.URL,
  },
  articleSection: CATEGORY_LABEL[post.data.category],
  keywords: post.data.tags.join(", "),
  inLanguage: "en",
};

const breadcrumbLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "@id": `${canonicalUrl}#breadcrumb`,
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: SITE.URL },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: new URL("/blog/", SITE.URL).href,
    },
    {
      "@type": "ListItem",
      position: 3,
      name: post.data.title,
      item: canonicalUrl,
    },
  ],
};

const relatedLd =
  related.length > 0
    ? {
        "@context": "https://schema.org",
        "@type": "ItemList",
        name: "Related posts",
        itemListElement: related.map((p, i) => ({
          "@type": "ListItem",
          position: i + 1,
          url: new URL(`/blog/${p.id}/`, SITE.URL).href,
          name: p.data.title,
        })),
      }
    : null;

const structured = relatedLd
  ? [webPageLd, articleLd, breadcrumbLd, relatedLd]
  : [webPageLd, articleLd, breadcrumbLd];
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  image={post.data.heroImage?.url ?? "/og.webp"}
  ogType="article"
  article={{
    publishedTime: post.data.publishDate.toISOString(),
    modifiedTime: (post.data.updatedDate ?? post.data.publishDate).toISOString(),
    author: OWNER.NAME,
    section: CATEGORY_LABEL[post.data.category],
    tags: post.data.tags,
  }}
  structuredData={structured}
>
  <ReadingProgress />

  <section class="mx-auto max-w-6xl px-5 pt-8 pb-6 md:pt-12 md:pb-8">
    <NeoButton href="/blog/" variant="secondary" size="sm" class="mb-6">
      ← Back to blog
    </NeoButton>

    <div class="flex flex-wrap items-center gap-3 mb-5">
      <TagPill
        tone={CATEGORY_TONE[post.data.category]}
        href={`/blog/category/${post.data.category}/`}
      >
        {CATEGORY_LABEL[post.data.category]}
      </TagPill>
      <span class="mono text-xs font-bold uppercase tracking-widest opacity-70 inline-flex items-center gap-1.5">
        <Icon name="lucide:calendar" class="h-3.5 w-3.5" />
        {fmtDate(post.data.publishDate)}
      </span>
      {
        post.data.updatedDate && (
          <span class="mono text-xs opacity-60 inline-flex items-center gap-1.5">
            <Icon name="lucide:refresh-cw" class="h-3.5 w-3.5" />
            Updated {fmtDate(post.data.updatedDate)}
          </span>
        )
      }
      <span class="mono text-xs font-bold uppercase tracking-widest opacity-70 inline-flex items-center gap-1.5">
        <Icon name="lucide:clock" class="h-3.5 w-3.5" />
        {rt}
      </span>
      <span class="mono text-xs font-bold uppercase tracking-widest opacity-70 inline-flex items-center gap-1.5">
        <Icon name="lucide:type" class="h-3.5 w-3.5" />
        {words.toLocaleString()} words
      </span>
    </div>

    <h1
      class="display text-[clamp(2.25rem,5.5vw,4.25rem)] max-w-4xl leading-[0.95] tracking-tight"
    >
      {post.data.title}
    </h1>
    <p
      class="mt-5 max-w-3xl text-base sm:text-lg md:text-xl text-ink-soft leading-snug"
    >
      {post.data.description}
    </p>

    <div class="mt-6 flex flex-wrap items-center gap-4 justify-between">
      <div class="inline-flex items-center gap-3">
        <span
          class="inline-flex h-10 w-10 items-center justify-center border-[2.5px] border-ink rounded-full bg-yellow text-ink shadow-neo-xs"
          aria-hidden="true"
        >
          <Icon name="lucide:user" class="h-5 w-5" />
        </span>
        <div class="leading-tight">
          <p class="font-bold text-sm">{OWNER.NAME}</p>
          <p class="mono text-[10px] font-bold uppercase tracking-widest opacity-70">
            Backend · Architect · AI
          </p>
        </div>
      </div>
      <ShareBar
        title={post.data.title}
        url={canonicalUrl}
        label="Share"
      />
    </div>

    {
      post.data.tags.length > 0 && (
        <ul class="flex flex-wrap gap-2 mt-6">
          {post.data.tags.map((t) => (
            <li>
              <TagPill tone="paper" size="sm" href={`/blog/tag/${tagSlug(t)}/`}>
                #{t}
              </TagPill>
            </li>
          ))}
        </ul>
      )
    }
  </section>

  {
    post.data.heroImage && (
      <section class="mx-auto max-w-6xl px-5 pb-10">
        <figure class="border-[3px] border-ink rounded-[4px] shadow-neo-md overflow-hidden bg-ink mx-auto max-w-5xl aspect-[16/10]">
          <img
            src={post.data.heroImage.url}
            alt={post.data.heroImage.alt}
            width="1600"
            height="1000"
            loading="eager"
            decoding="async"
            fetchpriority="high"
            class="w-full h-full object-cover"
          />
        </figure>
      </section>
    )
  }

  <section class="mx-auto max-w-6xl px-5 pb-10">
    <div class="grid gap-10 lg:grid-cols-[1fr_280px] lg:gap-12">
      <article class="prose max-w-3xl min-w-0">
        <Content />
      </article>
      <aside class="hidden lg:block">
        <div class="sticky top-24 space-y-5">
          <TableOfContents headings={headings} />
          {
            skillsChecklist.length > 0 && (
              <ChecklistBox
                title="Related skills"
                items={skillsChecklist}
                tone="cyan"
              />
            )
          }
          <NeoCard tone="paper" shadow="sm" class="space-y-3 !p-4">
            <p
              class="mono text-[10px] font-bold uppercase tracking-widest text-pink-deep"
            >
              ▸ Liked this?
            </p>
            <p class="text-sm font-bold leading-snug">
              Email when I ship the next one.
            </p>
            <NeoButton
              href="#newsletter"
              variant="primary"
              size="sm"
              fullWidth
            >
              Subscribe →
            </NeoButton>
          </NeoCard>
        </div>
      </aside>
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-10">
    <div
      class="max-w-4xl mx-auto border-y-[3px] border-ink py-6 flex flex-wrap items-center justify-between gap-4"
    >
      <p class="mono text-xs font-bold uppercase tracking-widest text-pink-deep">
        ▸ Made it to the end? Send it around.
      </p>
      <ShareBar
        title={post.data.title}
        url={canonicalUrl}
        label="Share"
      />
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-10">
    <PanelDivider shape="bolt" tone="pink" />
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-12">
    <AuthorFooter class="max-w-4xl mx-auto" />
  </section>

  {
    (prevPost || nextPost) && (
      <section class="mx-auto max-w-6xl px-5 pb-16">
        <div class="max-w-4xl mx-auto">
          <p class="mono text-xs font-bold uppercase tracking-widest opacity-60 mb-4 text-center">
            ▸ Keep reading
          </p>
          <nav
            class="grid gap-4 md:grid-cols-2"
            aria-label="Post navigation"
          >
            {prevPost ? (
              <a
                href={`/blog/${prevPost.id}/`}
                data-neo-hover
                class="group flex items-start gap-3 border-[3px] border-ink rounded-[4px] bg-paper p-5 shadow-neo-sm transition-all hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-md hover:bg-yellow"
              >
                <Icon
                  name="lucide:arrow-left"
                  class="h-5 w-5 mt-0.5 shrink-0"
                />
                <div class="flex-1 min-w-0">
                  <p class="mono text-[10px] font-bold uppercase tracking-widest opacity-70">
                    Newer post
                  </p>
                  <p class="heading text-base md:text-lg uppercase leading-tight mt-1">
                    {prevPost.data.title}
                  </p>
                </div>
              </a>
            ) : (
              <span />
            )}
            {nextPost ? (
              <a
                href={`/blog/${nextPost.id}/`}
                data-neo-hover
                class="group flex items-start gap-3 border-[3px] border-ink rounded-[4px] bg-paper p-5 shadow-neo-sm transition-all hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-md hover:bg-yellow md:text-right md:flex-row-reverse"
              >
                <Icon
                  name="lucide:arrow-right"
                  class="h-5 w-5 mt-0.5 shrink-0"
                />
                <div class="flex-1 min-w-0">
                  <p class="mono text-[10px] font-bold uppercase tracking-widest opacity-70">
                    Older post
                  </p>
                  <p class="heading text-base md:text-lg uppercase leading-tight mt-1">
                    {nextPost.data.title}
                  </p>
                </div>
              </a>
            ) : (
              <span />
            )}
          </nav>
        </div>
      </section>
    )
  }

  <HalftoneSection tone="bg" class="pb-16">
    <RelatedPosts posts={related} />
  </HalftoneSection>
</BaseLayout>
