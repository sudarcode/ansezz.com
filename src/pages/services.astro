---
import Page from "@/layouts/Page.astro";
import NeoCard from "@/components/neobrutalist/NeoCard.astro";
import NeoButton from "@/components/neobrutalist/NeoButton.astro";
import BurstBadge from "@/components/neobrutalist/BurstBadge.astro";
import TagPill from "@/components/neobrutalist/TagPill.astro";
import PanelDivider from "@/components/neobrutalist/PanelDivider.astro";
import HalftoneSection from "@/components/neobrutalist/HalftoneSection.astro";
import { Icon } from "astro-icon/components";
import {
  SERVICES,
  SERVICES_PAGE,
  SERVICES_FAQ,
  AVAILABLE_FOR,
  SITE,
} from "@/consts";
import { faqPage, breadcrumbList } from "@/lib/seo";

const faqLd = faqPage(SERVICES_FAQ);
const breadcrumbLd = breadcrumbList([
  { name: "Home", url: SITE.URL },
  { name: "Services", url: "/services/" },
]);
---

<Page
  title={SERVICES_PAGE.TITLE}
  description={SERVICES_PAGE.DESCRIPTION}
  eyebrow="Work with me"
  heading="Senior engineering, hired by the engagement."
  intro={SERVICES_PAGE.DESCRIPTION}
  structuredData={[faqLd, breadcrumbLd]}
>
  <!-- Service packages -->
  <section class="mx-auto max-w-6xl px-5 pb-14">
    <div class="mb-7">
      <BurstBadge tone="yellow" size="sm" class="mb-4">01</BurstBadge>
      <h2 class="display text-2xl md:text-3xl leading-tight">
        Pick a package.
      </h2>
      <p class="mono text-[11px] font-bold uppercase tracking-widest opacity-60 mt-2">
        ▸ Fixed scope · senior-only · remote-first
      </p>
    </div>

    <ul class="grid gap-6 md:grid-cols-2">
      {
        SERVICES.map((s, i) => (
          <li>
            <NeoCard
              tone={s.tone}
              shadow="md"
              tilt={i % 2 === 0 ? -0.3 : 0.3}
              class="flex h-full flex-col gap-4"
            >
              <h3 class="heading text-xl md:text-2xl uppercase leading-tight">
                {s.title}
              </h3>
              <p class="text-sm md:text-base leading-snug opacity-90">
                {s.body}
              </p>
              <ul class="space-y-2 mt-1">
                {s.bullets.map((b) => (
                  <li class="flex items-start gap-2 text-sm font-medium">
                    <Icon
                      name="lucide:check"
                      class="h-4 w-4 mt-0.5 shrink-0"
                    />
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-auto pt-3">
                <NeoButton href="/contact/" variant="ink" size="sm" fullWidth>
                  Start this →
                </NeoButton>
              </div>
            </NeoCard>
          </li>
        ))
      }
    </ul>
  </section>

  <section class="mx-auto max-w-6xl px-5 pb-6">
    <PanelDivider shape="zigzag" tone="cyan" />
  </section>

  <!-- How it works -->
  <section class="mx-auto max-w-6xl px-5 pb-14">
    <div class="mb-7">
      <BurstBadge tone="cyan" size="sm" class="mb-4">02</BurstBadge>
      <h2 class="display text-2xl md:text-3xl leading-tight">
        How it works.
      </h2>
      <p class="mono text-[11px] font-bold uppercase tracking-widest opacity-60 mt-2">
        ▸ No black box. You see progress, not promises.
      </p>
    </div>

    <ol class="grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        SERVICES_PAGE.HOW.map((step) => (
          <li>
            <NeoCard tone={step.tone} shadow="sm" class="flex h-full flex-col gap-3 !p-5">
              <div class="flex items-center justify-between">
                <span
                  class="inline-flex h-10 w-10 items-center justify-center border-[2.5px] border-ink rounded-full bg-paper text-ink shadow-neo-xs"
                  aria-hidden="true"
                >
                  <Icon name={step.icon} class="h-5 w-5" />
                </span>
                <span class="display text-2xl opacity-40">{step.step}</span>
              </div>
              <h3 class="heading text-lg uppercase leading-tight">
                {step.title}
              </h3>
              <p class="text-sm leading-snug opacity-90">{step.body}</p>
            </NeoCard>
          </li>
        ))
      }
    </ol>
  </section>

  <!-- Available for -->
  <section class="mx-auto max-w-6xl px-5 pb-14">
    <NeoCard tone="paper" class="space-y-4">
      <p class="mono text-xs font-bold uppercase tracking-widest text-pink-deep">
        ▸ Also available for
      </p>
      <ul class="flex flex-wrap gap-2">
        {
          AVAILABLE_FOR.map((role) => (
            <li>
              <TagPill tone="yellow" size="md">
                {role}
              </TagPill>
            </li>
          ))
        }
      </ul>
    </NeoCard>
  </section>

  <!-- FAQ -->
  <section class="mx-auto max-w-6xl px-5 pb-16">
    <div class="mb-7">
      <BurstBadge tone="pink" size="sm" class="mb-4">03</BurstBadge>
      <h2 class="display text-2xl md:text-3xl leading-tight">
        Questions, answered.
      </h2>
    </div>
    <div class="grid gap-4 md:grid-cols-2 max-w-5xl">
      {
        SERVICES_FAQ.map((f) => (
          <details class="group border-[3px] border-ink rounded-[4px] bg-paper shadow-neo-sm">
            <summary class="cursor-pointer list-none flex items-center justify-between gap-3 p-4 font-bold">
              <span>{f.question}</span>
              <Icon
                name="lucide:plus"
                class="h-5 w-5 shrink-0 transition-transform group-open:rotate-45"
              />
            </summary>
            <p class="px-4 pb-4 text-sm leading-relaxed opacity-90">
              {f.answer}
            </p>
          </details>
        ))
      }
    </div>
  </section>

  <HalftoneSection tone="blue" bordered class="py-14 text-paper">
    <div class="mx-auto max-w-5xl px-5 grid gap-6 md:grid-cols-[1fr_auto] items-center">
      <div>
        <p class="display text-3xl md:text-4xl leading-tight">
          Ready when you are.
        </p>
        <p class="mt-3 text-base text-paper/80">
          Free 30-minute discovery call. I'll tell you honestly if it's a fit.
        </p>
      </div>
      <div class="flex flex-wrap gap-3">
        <NeoButton href={SITE.BOOKING_URL} variant="primary" size="lg">
          <Icon name="lucide:calendar" class="h-4 w-4" />
          Book a call
        </NeoButton>
        <NeoButton href="/contact/" variant="ink" size="lg">
          Contact →
        </NeoButton>
      </div>
    </div>
  </HalftoneSection>
</Page>
