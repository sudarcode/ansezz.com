---
import HalftoneSection from "@/components/neobrutalist/HalftoneSection.astro";
import { STATS } from "@/consts";
---

<HalftoneSection tone="pink" bordered class="py-12 md:py-16">
  <div class="mx-auto max-w-5xl px-5 grid grid-cols-2 md:grid-cols-4 gap-6">
    {
      STATS.map((s) => (
        <div class="text-center text-ink">
          <p class="display text-5xl md:text-6xl">{s.value}</p>
          <p class="mono text-xs font-bold uppercase tracking-widest mt-2">
            {s.label}
          </p>
        </div>
      ))
    }
  </div>
</HalftoneSection>
