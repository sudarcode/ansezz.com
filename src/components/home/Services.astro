---
import NeoCard from "@/components/neobrutalist/NeoCard.astro";
import NeoButton from "@/components/neobrutalist/NeoButton.astro";
import BurstBadge from "@/components/neobrutalist/BurstBadge.astro";
import { Icon } from "astro-icon/components";
import { SERVICES } from "@/consts";
---

<section
  id="services"
  class="relative mx-auto max-w-6xl px-5 py-16 md:py-24 scroll-mt-24"
>
  <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-end mb-10">
    <div class="max-w-2xl">
      <BurstBadge tone="pink" size="sm" class="mb-5">05</BurstBadge>
      <h2 class="display text-[clamp(2rem,4.5vw,3.5rem)] leading-[0.95]">
        Engagements I
        <span class="bg-yellow inline-block px-2 -mx-1">say yes to</span>.
      </h2>
      <p class="mt-4 text-base md:text-lg text-ink-soft leading-snug">
        Scoped, time-boxed, and senior. Pick a lane below, or describe a hybrid
        — I'll tell you honestly if it's a fit.
      </p>
    </div>
    <NeoButton href="/contact/" variant="ink" size="lg">
      <Icon name="lucide:mail" class="h-4 w-4" />
      Start a project
    </NeoButton>
  </div>

  <ul class="grid gap-6 md:grid-cols-2">
    {
      SERVICES.map((s, i) => (
        <li>
          <NeoCard
            tone={s.tone}
            shadow="md"
            tilt={i % 2 === 0 ? -0.3 : 0.3}
            class="h-full flex flex-col gap-4"
          >
            <h3 class="heading text-xl md:text-2xl uppercase leading-tight">
              {s.title}
            </h3>
            <p class="text-sm md:text-base leading-snug opacity-90">{s.body}</p>
            <ul class="space-y-1.5 text-sm">
              {s.bullets.map((b) => (
                <li class="flex items-start gap-2">
                  <Icon
                    name="lucide:check"
                    class="h-4 w-4 mt-1 shrink-0 opacity-80"
                  />
                  <span>{b}</span>
                </li>
              ))}
            </ul>
          </NeoCard>
        </li>
      ))
    }
  </ul>
</section>
