---
import StickyNote from "@/components/neobrutalist/StickyNote.astro";
import TagPill from "@/components/neobrutalist/TagPill.astro";
import RobotMascot from "@/components/neobrutalist/RobotMascot.astro";
import NeoButton from "@/components/neobrutalist/NeoButton.astro";
import PageNumber from "@/components/neobrutalist/PageNumber.astro";
import AvailabilityBadge from "@/components/neobrutalist/AvailabilityBadge.astro";
import { Icon } from "astro-icon/components";
import { OWNER, SITE } from "@/consts";

const heroTags = [
  "Laravel",
  "Anthropic Claude",
  "Model Context Protocol",
  "Shopify Plus",
  "pgvector",
];
const tagTones = ["red", "purple", "cyan", "green", "blue"] as const;

const stats = [
  { v: "12+", l: "Years" },
  { v: "60+", l: "Builds" },
  { v: "3", l: "Continents" },
];
---

<section
  class="relative mx-auto max-w-6xl px-5 pt-10 pb-14 md:pt-14 md:pb-20 lg:pt-16 lg:pb-24"
>
  <PageNumber
    n="01"
    position="tr"
    class="hidden md:block !text-[12rem] !text-ink/[0.05]"
  />

  <div
    class="grid gap-10 lg:gap-14 lg:grid-cols-[minmax(0,1.4fr)_minmax(0,1fr)] lg:items-center"
  >
    <div class="min-w-0">
      <p
        class="mono text-xs sm:text-sm font-bold uppercase tracking-widest text-pink-deep mb-6 inline-flex items-center gap-2"
      >
        <span class="inline-block w-5 sm:w-6 h-[3px] bg-pink-deep"></span>
        Senior Lead Engineer · {OWNER.YEARS_EXPERIENCE}+ yrs · Remote since {
          OWNER.REMOTE_SINCE
        }
      </p>

      <h1
        class="display text-[clamp(2.5rem,6vw,4.75rem)] leading-[0.95] tracking-tight"
      >
        Backends that survive prod.
        <span class="block mt-2">AI features with</span>
        <span class="block mt-3">
          <span
            class="inline-block bg-pink text-paper px-3 py-1 border-[3px] border-ink shadow-neo-md whitespace-nowrap"
          >
            evals, not vibes.
          </span>
        </span>
      </h1>

      <p
        class="mt-7 max-w-2xl text-base sm:text-lg md:text-xl text-ink-soft leading-snug font-medium"
      >
        Senior Lead Backend Engineer, Software Architect, and AI Engineer.
        Production Laravel SaaS, Shopify Plus apps, and AI features —
        Claude, MCP, RAG — for founders, agencies, and product teams.
      </p>

      <div class="mt-7">
        <AvailabilityBadge label={OWNER.STATUS} />
      </div>

      <div class="mt-5 flex flex-wrap items-center gap-3">
        <NeoButton href="/contact/" variant="danger" size="lg">
          <Icon name="lucide:mail" class="h-4 w-4" />
          Hire me
        </NeoButton>
        <NeoButton href={SITE.BOOKING_URL} variant="primary" size="lg">
          <Icon name="lucide:calendar" class="h-4 w-4" />
          Book a 15-min call
        </NeoButton>
        <NeoButton href="/work/" variant="secondary" size="lg">
          See work →
        </NeoButton>
      </div>

      <div class="mt-9">
        <p
          class="mono text-[11px] font-bold uppercase tracking-widest opacity-60 mb-2"
        >
          ▸ Daily stack
        </p>
        <ul class="flex flex-wrap gap-2">
          {
            heroTags.map((t, i) => (
              <li>
                <TagPill tone={tagTones[i % tagTones.length]} size="sm">
                  {t}
                </TagPill>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <aside
      class="relative isolate w-full max-w-[420px] mx-auto lg:mx-0 lg:max-w-none"
      data-mascot="hero"
    >
      <div
        class="relative border-[3px] border-ink bg-cyan rounded-[6px] shadow-neo-xl overflow-hidden"
      >
        <span
          class="absolute inset-0 halftone opacity-25 pointer-events-none"
          aria-hidden="true"></span>

        <header
          class="relative z-10 flex items-center justify-between gap-2 border-b-[3px] border-ink bg-ink px-3 py-2 text-bg"
        >
          <span class="mono text-[10px] font-bold uppercase tracking-widest">
            ▸ trading-card.dev
          </span>
          <span
            class="inline-flex items-center gap-1.5 mono text-[10px] font-bold uppercase tracking-widest"
          >
            <span
              class="h-1.5 w-1.5 rounded-full bg-green inline-block neo-pulse-dot"
            ></span>
            LIVE
          </span>
        </header>

        <div
          class="relative px-5 pt-5 pb-4 flex flex-col items-center text-center gap-3"
        >
          <RobotMascot
            tone="yellow"
            size={130}
            class="md:!w-[150px] md:!h-[150px]"
          />
          <div>
            <p
              class="display text-2xl md:text-3xl leading-[1] tracking-tight"
            >
              {OWNER.NAME}
            </p>
            <p
              class="mono text-[10px] font-bold uppercase tracking-widest mt-1 opacity-80"
            >
              Backend · Architect · AI
            </p>
          </div>
        </div>

        <ul
          class="relative z-10 grid grid-cols-3 border-t-[3px] border-ink"
        >
          {
            stats.map((s, i) => (
              <li
                class:list={[
                  "px-2 py-3 text-center bg-paper",
                  i < 2 && "border-r-[3px] border-ink",
                ]}
              >
                <p class="display text-2xl md:text-3xl leading-none">
                  {s.v}
                </p>
                <p class="mono text-[9px] font-bold uppercase tracking-widest opacity-70 mt-1">
                  {s.l}
                </p>
              </li>
            ))
          }
        </ul>

        <footer
          class="relative z-10 border-t-[3px] border-ink bg-yellow px-4 py-3"
        >
          <p
            class="mono text-[10px] font-bold uppercase tracking-widest mb-1"
          >
            ▸ Now shipping
          </p>
          <p class="text-xs font-bold leading-snug">
            {OWNER.CURRENTLY}
          </p>
        </footer>
      </div>

      <div
        class="absolute -top-4 -right-4 md:-top-5 md:-right-6 z-20 rotate-[7deg]"
      >
        <StickyNote tone="pink" tilt={0} class="max-w-[180px]">
          <p
            class="mono text-[10px] font-bold uppercase tracking-widest mb-1 text-paper"
          >
            ▸ Open
          </p>
          <p class="text-xs font-bold leading-snug text-paper">
            Currently open · Senior / Lead / Advisory.
          </p>
        </StickyNote>
      </div>
    </aside>
  </div>
</section>
