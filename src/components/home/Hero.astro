---
import SpeechBubble from "@/components/neobrutalist/SpeechBubble.astro";
import StickyNote from "@/components/neobrutalist/StickyNote.astro";
import TagPill from "@/components/neobrutalist/TagPill.astro";
import RobotMascot from "@/components/neobrutalist/RobotMascot.astro";
import { OWNER, AVAILABLE_FOR } from "@/consts";

const tones = ["yellow", "pink", "cyan", "green", "red", "blue"] as const;
---

<section class="relative mx-auto max-w-5xl px-5 pt-10 pb-16 md:pt-20 md:pb-24">
  <p class="mono text-sm font-bold uppercase tracking-widest text-pink-deep mb-6">
    ▸ Anass Ez-zouaine · {OWNER.REMOTE_SINCE}—now
  </p>

  <div class="grid gap-8 md:gap-10 md:grid-cols-[minmax(0,1fr)_auto] md:items-end">
    <div class="min-w-0">
      <h1 class="display text-[clamp(2.25rem,6.5vw,4.5rem)]">
        Senior Lead Backend Engineer
        <span class="block">
          Software Architect &amp;
          <span class="bg-pink text-paper px-2 -mx-1 inline-block whitespace-nowrap">
            AI Engineer
          </span>
        </span>
      </h1>
      <p class="mt-5 max-w-2xl text-base sm:text-lg md:text-xl text-ink/80 leading-snug font-medium">
        {OWNER.TAGLINE}
      </p>

      <div class="mt-7 inline-block max-w-full">
        <SpeechBubble tone="yellow" tail="bl">
          <span class="text-base md:text-lg">Laravel + AI = unfair shipping speed.</span>
        </SpeechBubble>
      </div>

      <div class="mt-9">
        <p
          class="mono text-xs font-bold uppercase tracking-widest opacity-60 mb-3"
        >
          Available for
        </p>
        <ul class="flex flex-wrap gap-2">
          {
            AVAILABLE_FOR.map((label, i) => (
              <li>
                <TagPill tone={tones[i % tones.length]} size="sm">{label}</TagPill>
              </li>
            ))
          }
        </ul>
      </div>
    </div>

    <div class="relative flex justify-center md:justify-end md:self-end">
      <RobotMascot tone="cyan" size={180} class="md:!w-[200px] md:!h-[200px]" />
      <div class="absolute -top-2 -right-2 md:-right-4">
        <StickyNote tone="yellow" tilt={6} class="max-w-[180px] md:max-w-[200px]">
          <p class="mono text-[10px] font-bold uppercase tracking-widest mb-1">
            Currently
          </p>
          <p class="text-xs md:text-sm font-bold leading-snug">{OWNER.CURRENTLY}</p>
        </StickyNote>
      </div>
    </div>
  </div>
</section>
