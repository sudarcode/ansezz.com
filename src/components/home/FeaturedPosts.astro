---
import { getCollection } from "astro:content";
import PostCard from "@/components/blog/PostCard.astro";
import BurstBadge from "@/components/neobrutalist/BurstBadge.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const featured = posts
  .sort(
    (a, b) =>
      Number(b.data.featured) - Number(a.data.featured) ||
      b.data.publishDate.getTime() - a.data.publishDate.getTime(),
  )
  .slice(0, 3);
---

<section class="mx-auto max-w-5xl px-5 py-16 md:py-20 relative">
  <div class="flex items-end justify-between gap-6 mb-10 flex-wrap">
    <div>
      <BurstBadge tone="yellow" size="sm" class="mb-4">02</BurstBadge>
      <h2 class="display text-3xl md:text-4xl">From the blog</h2>
      <p class="mt-3 text-ink/70 max-w-md">
        Notes from the trenches — Laravel internals, AI agent design, Shopify
        Plus.
      </p>
    </div>
    <a
      href="/blog/"
      class="inline-flex items-center gap-2 border-[3px] border-ink bg-paper px-5 py-2.5 font-bold uppercase text-sm shadow-neo-sm transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-neo-md hover:bg-yellow"
    >
      All posts →
    </a>
  </div>
  {
    featured.length === 0 ? (
      <p class="border-[3px] border-dashed border-ink p-8 text-center font-bold">
        Blog post coming soon. Pinky promise.
      </p>
    ) : (
      <div class="grid gap-6 md:grid-cols-3">
        {featured.map((post) => (
          <PostCard post={post} />
        ))}
      </div>
    )
  }
</section>
