---
import { getCollection } from "astro:content";
import PostCard from "@/components/blog/PostCard.astro";
import BurstBadge from "@/components/neobrutalist/BurstBadge.astro";
import NeoButton from "@/components/neobrutalist/NeoButton.astro";

const posts = await getCollection("blog", ({ data }) => !data.draft);
const featured = posts
  .sort(
    (a, b) =>
      Number(b.data.featured) - Number(a.data.featured) ||
      b.data.publishDate.getTime() - a.data.publishDate.getTime(),
  )
  .slice(0, 3);

const tones = ["yellow", "cyan", "green"] as const;
---

<section class="mx-auto max-w-6xl px-5 py-16 md:py-24 relative">
  <div class="grid gap-8 md:grid-cols-[1fr_auto] md:items-end mb-10">
    <div class="max-w-2xl">
      <BurstBadge tone="yellow" size="sm" class="mb-5">02</BurstBadge>
      <h2 class="display text-[clamp(2rem,4.5vw,3.25rem)] leading-[0.95]">
        From the
        <span class="bg-yellow inline-block px-2 -mx-1">trenches</span>.
      </h2>
      <p class="mt-4 text-base md:text-lg text-ink-soft leading-snug">
        Notes on Laravel internals, AI agent design, Shopify Plus, and the
        occasional hot take. No fluff.
      </p>
    </div>
    <NeoButton href="/blog/" variant="secondary" size="lg">
      All posts →
    </NeoButton>
  </div>
  {
    featured.length === 0 ? (
      <p class="border-[3px] border-dashed border-ink rounded-[4px] p-8 text-center font-bold">
        Blog post coming soon. Pinky promise.
      </p>
    ) : (
      <ul class="grid gap-6 md:grid-cols-3">
        {featured.map((post, i) => (
          <li>
            <PostCard
              post={post}
              eager={i < 3}
              tone={tones[i % tones.length]}
            />
          </li>
        ))}
      </ul>
    )
  }
</section>
