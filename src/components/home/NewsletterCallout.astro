---
import NeoButton from "@/components/neobrutalist/NeoButton.astro";
import HalftoneSection from "@/components/neobrutalist/HalftoneSection.astro";
import BurstBadge from "@/components/neobrutalist/BurstBadge.astro";
import { Icon } from "astro-icon/components";

interface Props {
  action?: string;
  class?: string;
}

const { action = "https://buttondown.email/api/emails/embed-subscribe/ansezz", class: className = "" } = Astro.props;
---

<HalftoneSection
  tone="yellow"
  bordered
  class:list={["py-16 md:py-24", className]}
>
  <div class="mx-auto max-w-5xl px-5 grid gap-8 md:grid-cols-[1fr_auto] items-center">
    <div class="max-w-2xl">
      <div class="mb-5">
        <BurstBadge tone="pink" size="sm">06</BurstBadge>
      </div>
      <h2 class="display text-[clamp(2rem,5vw,3.75rem)] leading-[0.95]">
        The newsletter
        <span class="bg-ink text-bg px-2 inline-block">no fluff</span>.
      </h2>
      <p class="mt-5 text-base md:text-lg text-ink/80 leading-snug max-w-xl font-medium">
        One short email when I ship a post. Laravel internals, AI engineering
        notes, hot takes on Shopify Plus. No drip funnels, no upsells.
      </p>
    </div>

    <form
      method="post"
      action={action}
      target="_blank"
      class="w-full md:w-auto md:min-w-[340px] flex flex-col gap-3"
    >
      <label class="block">
        <span class="sr-only">Email address</span>
        <div class="relative">
          <Icon
            name="lucide:mail"
            class="absolute left-3 top-1/2 -translate-y-1/2 h-5 w-5 pointer-events-none"
          />
          <input
            type="email"
            name="email"
            required
            placeholder="you@domain.com"
            autocomplete="email"
            class="w-full border-[3px] border-ink rounded-[4px] bg-paper pl-10 pr-4 py-3.5 text-base font-medium shadow-neo-md placeholder:text-ink/40 focus:outline-none focus:translate-x-[-2px] focus:translate-y-[-2px] focus:shadow-neo-lg transition-all"
          />
        </div>
      </label>
      <input type="hidden" name="embed" value="1" />
      <NeoButton type="submit" variant="ink" size="lg" fullWidth>
        Subscribe →
      </NeoButton>
      <p class="mono text-[10px] uppercase tracking-widest opacity-60 text-center">
        Unsubscribe anytime. Zero spam.
      </p>
    </form>
  </div>
</HalftoneSection>
