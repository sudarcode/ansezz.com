---
import HalftoneSection from "@/components/neobrutalist/HalftoneSection.astro";
import PanelDivider from "@/components/neobrutalist/PanelDivider.astro";
---

<HalftoneSection tone="pink" bordered class="py-16 md:py-24">
  <div class="mx-auto max-w-5xl px-5 text-center text-ink">
    <p
      class="mono text-xs font-bold uppercase tracking-widest opacity-70 mb-4"
    >
      ▸ Operating principle
    </p>

    <figure class="relative inline-block max-w-3xl">
      <div
        class="relative inline-block bg-paper border-[3px] border-ink rounded-[8px] shadow-neo-lg px-6 py-8 md:px-12 md:py-14"
      >
        <blockquote
          class="display text-[clamp(1.75rem,4.5vw,3.5rem)] leading-[1] tracking-tight"
        >
          Ship the thing.
          <span class="block">
            Then make it
            <span class="bg-yellow inline-block px-2 -mx-1">unfair</span>.
          </span>
        </blockquote>

        <svg
          class="absolute -bottom-6 left-12 w-12 h-9"
          viewBox="0 0 48 36"
          aria-hidden="true"
        >
          <path
            d="M0 0 L48 0 L12 36 Z"
            fill="var(--color-paper)"
          />
          <path
            d="M0 0 L48 0 L12 36 Z"
            fill="none"
            stroke="var(--color-ink)"
            stroke-width="3"
            stroke-linejoin="round"
          />
        </svg>
      </div>
    </figure>

    <p class="mt-12 text-base md:text-lg max-w-2xl mx-auto opacity-90">
      Production-ready, observable, opinionated. Backed by tests, types, and
      ten years of remote-only scar tissue.
    </p>

    <div class="mt-8">
      <PanelDivider tone="yellow" shape="bolt" class="!my-0" />
    </div>
  </div>
</HalftoneSection>
