---
import TagPill from "@/components/neobrutalist/TagPill.astro";
import { CATEGORY_LABEL, CATEGORY_TONE, type BlogCategory } from "@/consts";

interface Props {
  date: Date;
  updatedDate?: Date;
  category: BlogCategory;
  readingTime: string;
  showTime?: boolean;
  hideCategory?: boolean;
  linkCategory?: boolean;
}

const {
  date,
  updatedDate,
  category,
  readingTime,
  showTime = true,
  hideCategory = false,
  linkCategory = true,
} = Astro.props;

const fmt = (d: Date) =>
  d.toLocaleDateString("en-US", { year: "numeric", month: "short", day: "numeric" });
---

<div class="flex flex-wrap items-center gap-3 text-sm">
  {
    !hideCategory && (
      <TagPill
        tone={CATEGORY_TONE[category]}
        size="sm"
        href={linkCategory ? `/blog/category/${category}/` : undefined}
      >
        {CATEGORY_LABEL[category]}
      </TagPill>
    )
  }
  <time datetime={date.toISOString()} class="mono font-bold uppercase tracking-wider opacity-70">
    {fmt(date)}
  </time>
  {
    updatedDate && (
      <span class="mono text-xs opacity-60">
        · Updated {fmt(updatedDate)}
      </span>
    )
  }
  {
    showTime && (
      <span class="mono text-xs opacity-60">· {readingTime}</span>
    )
  }
</div>
