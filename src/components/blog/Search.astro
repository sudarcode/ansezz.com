---
// Static full-text search powered by Pagefind. The /pagefind/* assets
// are generated by the `pagefind` CLI in the build script, so search is
// inert in `astro dev` and live in the built site.
---

<section class="mx-auto max-w-6xl px-5 pb-2" id="search">
  <div
    class="border-[3px] border-ink rounded-[4px] bg-paper p-4 md:p-5 shadow-neo-sm"
  >
    <label
      for="blog-search-input"
      class="mono text-[10px] font-bold uppercase tracking-widest text-pink-deep mb-3 block"
    >
      ▸ Search the blog
    </label>
    <div id="pagefind-search" data-pagefind-search></div>
    <noscript>
      <p class="text-sm opacity-70">Search needs JavaScript enabled.</p>
    </noscript>
  </div>
</section>

<script>
  import "@/scripts/blog-search";
</script>

<style is:global>
  /* Neobrutalist skin for the Pagefind UI */
  #pagefind-search {
    --pagefind-ui-scale: 0.9;
    --pagefind-ui-primary: var(--color-ink);
    --pagefind-ui-text: var(--color-ink);
    --pagefind-ui-background: var(--color-paper);
    --pagefind-ui-border: var(--color-ink);
    --pagefind-ui-tag: var(--color-yellow);
    --pagefind-ui-border-width: 3px;
    --pagefind-ui-border-radius: 4px;
    --pagefind-ui-font: var(--font-sans);
  }
  #pagefind-search .pagefind-ui__search-input {
    font-weight: 700;
    box-shadow: var(--shadow-neo-xs);
  }
  #pagefind-search .pagefind-ui__result {
    border-bottom: 2px solid var(--color-ink);
  }
  #pagefind-search .pagefind-ui__result-title a {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: -0.01em;
  }
</style>
