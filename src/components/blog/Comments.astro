---
import { COMMENTS } from "@/consts";

// Renders nothing until the owner enables giscus in consts.ts.
const ready =
  COMMENTS.ENABLED && COMMENTS.REPO_ID !== "" && COMMENTS.CATEGORY_ID !== "";
---

{
  ready && (
    <section class="mx-auto max-w-6xl px-5 pb-12">
      <div class="max-w-4xl mx-auto">
        <p class="mono text-xs font-bold uppercase tracking-widest text-pink-deep mb-4">
          ▸ Comments
        </p>
        <div
          id="giscus-mount"
          class="border-[3px] border-ink rounded-[4px] bg-paper p-4 shadow-neo-sm"
          data-giscus-repo={COMMENTS.REPO}
          data-giscus-repo-id={COMMENTS.REPO_ID}
          data-giscus-category={COMMENTS.CATEGORY}
          data-giscus-category-id={COMMENTS.CATEGORY_ID}
          data-giscus-mapping={COMMENTS.MAPPING}
          data-giscus-reactions={COMMENTS.REACTIONS ? "1" : "0"}
        />
      </div>
    </section>
  )
}

{
  ready && (
    <script>
      import "@/scripts/giscus";
    </script>
  )
}
