---
import type { CollectionEntry } from "astro:content";
import PostCard from "./PostCard.astro";

interface Props {
  posts: CollectionEntry<"blog">[];
}

const { posts } = Astro.props;

const tones = ["yellow", "cyan", "green"] as const;
---

{
  posts.length > 0 && (
    <section class="mx-auto max-w-5xl px-5 mt-20 mb-10">
      <h2 class="display text-3xl md:text-4xl mb-8">Keep reading</h2>
      <ul class="grid gap-6 md:grid-cols-3">
        {posts.map((p, i) => (
          <li>
            <PostCard post={p} tone={tones[i % tones.length]} eager />
          </li>
        ))}
      </ul>
    </section>
  )
}
