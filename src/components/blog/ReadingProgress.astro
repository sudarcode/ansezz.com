---
// Sticky reading progress bar shown under header on article pages.
---

<div
  class="sticky top-[56px] md:top-[60px] z-30 h-[3px] w-full bg-bg/0 pointer-events-none"
  aria-hidden="true"
>
  <div
    id="reading-progress-bar"
    class="h-full origin-left bg-pink transition-[width] duration-100 ease-out"
    style="width: 0%;"
  ></div>
</div>

<script>
  const bar = document.getElementById("reading-progress-bar");
  if (bar instanceof HTMLElement) {
    const article =
      document.querySelector<HTMLElement>("article.prose") ?? document.body;
    function update() {
      if (!(bar instanceof HTMLElement)) return;
      const rect = article.getBoundingClientRect();
      const start = rect.top + window.scrollY;
      const total = rect.height - window.innerHeight;
      const current = window.scrollY - start;
      const pct = Math.min(100, Math.max(0, (current / Math.max(1, total)) * 100));
      bar.style.width = `${pct}%`;
    }
    document.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update);
    update();
  }
</script>
