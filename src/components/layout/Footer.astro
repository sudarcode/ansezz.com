---
import { Icon } from "astro-icon/components";
import { SITE, SOCIALS } from "@/consts";
import { externalLinkAttrs } from "@/lib/links";

const year = new Date().getFullYear();
---

<footer class="mt-24 border-t-[3px] border-ink bg-ink text-bg">
  <div class="mx-auto max-w-5xl px-5 py-10 grid gap-8 md:grid-cols-3">
    <div>
      <p class="display text-3xl">
        {SITE.SHORT_TITLE}<span class="text-pink">.</span>
      </p>
      <p class="mt-3 text-sm opacity-80 max-w-xs">{SITE.DESCRIPTION}</p>
    </div>
    <div>
      <p class="text-xs font-bold uppercase tracking-wider opacity-60 mb-3">
        Elsewhere
      </p>
      <ul class="space-y-2">
        {
          SOCIALS.map((s) => (
            <li>
              <a
                href={s.HREF}
                {...externalLinkAttrs(s.HREF)}
                class="inline-flex items-center gap-2 text-sm font-bold hover:bg-yellow hover:text-ink px-1 transition-colors"
              >
                <Icon name={s.ICON} class="h-4 w-4" />
                {s.NAME}
              </a>
            </li>
          ))
        }
      </ul>
    </div>
    <div>
      <p class="text-xs font-bold uppercase tracking-wider opacity-60 mb-3">
        Based in
      </p>
      <p class="text-sm font-bold">{SITE.LOCATION}</p>
      <p class="text-sm opacity-70">{SITE.TZ} · Remote-first</p>
    </div>
  </div>
  <div class="border-t border-bg/20">
    <div
      class="mx-auto max-w-5xl px-5 py-4 flex flex-col md:flex-row justify-between items-start md:items-center gap-3 text-xs"
    >
      <span class="opacity-60">© {year} Anass Ez-zouaine</span>
      <div class="flex flex-wrap items-center gap-x-4 gap-y-1">
        <a href="/privacy/" class="opacity-80 hover:opacity-100 hover:bg-yellow hover:text-ink px-1 transition-colors">
          Privacy
        </a>
        <a href="/rss.xml" class="opacity-80 hover:opacity-100 hover:bg-yellow hover:text-ink px-1 transition-colors">
          RSS
        </a>
        <span class="mono opacity-60">Built with Astro ✦</span>
      </div>
    </div>
  </div>
</footer>
