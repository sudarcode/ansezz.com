---
import { NAV } from "@/consts";

interface Props {
  vertical?: boolean;
}

const { vertical = false } = Astro.props;

const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname === href || pathname.startsWith(href + "/");
}
---

<nav
  aria-label="Primary"
  class:list={[
    vertical ? "flex flex-col gap-1" : "flex items-center gap-1",
  ]}
>
  {
    NAV.map((item) => {
      const active = isActive(item.HREF);
      return (
        <a
          href={item.HREF}
          aria-current={active ? "page" : undefined}
          class:list={[
            "font-bold uppercase border-[2px] border-transparent transition-colors",
            vertical
              ? "block px-3 py-2.5 text-base"
              : "px-3 py-1.5 text-sm",
            active
              ? "bg-ink text-bg border-ink"
              : "hover:bg-yellow hover:border-ink",
          ]}
        >
          {item.LABEL}
        </a>
      );
    })
  }
</nav>
