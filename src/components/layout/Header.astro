---
import Nav from "./Nav.astro";
import ThemeToggle from "./ThemeToggle.astro";
import { Icon } from "astro-icon/components";
import { SITE } from "@/consts";
import { externalLinkAttrs } from "@/lib/links";
---

<header
  class="sticky top-0 z-40 border-b-[3px] border-ink bg-bg"
>
  <div
    class="mx-auto flex max-w-5xl items-center justify-between px-5 py-3 gap-4"
  >
    <a
      href="/"
      class="display text-2xl tracking-tight hover:bg-yellow px-1.5 -mx-1.5 transition-colors"
    >
      {SITE.SHORT_TITLE}<span class="text-pink">.</span>
    </a>
    <div class="hidden md:flex items-center gap-3">
      <Nav />
      <ThemeToggle />
      <a
        href="/contact/"
        class="inline-flex items-center gap-1.5 border-[2.5px] border-ink bg-pink text-paper px-3.5 py-1.5 text-xs font-bold uppercase tracking-wide shadow-neo-xs transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-neo-sm"
        aria-label="Contact me"
      >
        <Icon name="lucide:mail" class="h-3.5 w-3.5" />
        Hire me
      </a>
    </div>

    <div class="flex items-center gap-2 md:hidden">
      <ThemeToggle />
      <button
        id="mobile-menu-toggle"
        type="button"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Toggle menu"
        class="inline-flex items-center justify-center h-10 w-10 border-[2px] border-ink bg-paper shadow-neo-sm transition-all hover:bg-yellow"
      >
        <Icon name="lucide:menu" class="h-5 w-5 menu-icon-open" />
        <Icon name="lucide:x" class="h-5 w-5 menu-icon-close hidden" />
      </button>
    </div>

  <div
    id="mobile-menu"
    hidden
    class="md:hidden border-t-[3px] border-ink bg-bg"
  >
    <div class="mx-auto max-w-5xl px-5 py-4 space-y-3">
      <Nav vertical />
      <a
        href="/contact/"
        class="flex items-center justify-center gap-2 border-[3px] border-ink bg-pink text-paper px-4 py-3 font-bold uppercase text-sm shadow-neo-sm transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-neo-md"
        aria-label="Contact me"
      >
        <Icon name="lucide:mail" class="h-4 w-4" />
        Hire me
      </a>
      <a
        href={SITE.RESUME_URL}
        {...externalLinkAttrs(SITE.RESUME_URL)}
        class="flex items-center justify-center gap-2 border-[2.5px] border-ink bg-paper px-4 py-2.5 font-bold uppercase text-xs shadow-neo-xs transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-neo-sm"
        aria-label="Download resume PDF"
      >
        <Icon name="lucide:download" class="h-4 w-4" />
        Resume (PDF)
      </a>
    </div>
  </div>

  <noscript>
    <style>#mobile-menu-toggle { display: none !important; }</style>
    <div class="md:hidden border-t-[3px] border-ink bg-bg">
      <div class="mx-auto max-w-5xl px-5 py-4 space-y-3">
        <Nav vertical />
        <a
          href="/contact/"
          class="flex items-center justify-center gap-2 border-[3px] border-ink bg-pink text-paper px-4 py-3 font-bold uppercase text-sm shadow-neo-sm"
        >
          <Icon name="lucide:mail" class="h-4 w-4" />
          Hire me
        </a>
        <a
          href={SITE.RESUME_URL}
          class="flex items-center justify-center gap-2 border-[2.5px] border-ink bg-paper px-4 py-2.5 font-bold uppercase text-xs shadow-neo-xs"
        >
          <Icon name="lucide:download" class="h-4 w-4" />
          Resume (PDF)
        </a>
      </div>
    </div>
  </noscript>
</header>

<script>
  import "@/scripts/mobile-menu";
</script>
