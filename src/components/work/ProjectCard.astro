---
import type { CollectionEntry } from "astro:content";
import TagPill from "@/components/neobrutalist/TagPill.astro";
import NeoButton from "@/components/neobrutalist/NeoButton.astro";
import { Icon } from "astro-icon/components";

type Tone = "paper" | "yellow" | "pink" | "cyan" | "green" | "red" | "purple";

interface Props {
  entry: CollectionEntry<"work">;
  tone?: Tone;
}

const { entry, tone = "paper" } = Astro.props;

const toneClass: Record<Tone, string> = {
  paper: "bg-paper text-ink",
  yellow: "bg-yellow text-ink",
  pink: "bg-pink text-ink",
  cyan: "bg-cyan text-ink",
  green: "bg-green text-ink",
  red: "bg-red text-ink",
  purple: "bg-purple text-paper",
};

const tagTone = tone === "paper" ? "yellow" : "paper";
---

<article
  data-neo-hover
  class:list={[
    "group relative flex h-full flex-col gap-4 border-[3px] border-ink rounded-[4px] p-6 md:p-7 shadow-neo-md transition-all duration-150 hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-lg",
    toneClass[tone],
  ]}
>
  <header class="flex items-start justify-between gap-3 flex-wrap">
    <div>
      <p class="mono text-[10px] font-bold uppercase tracking-widest opacity-70 mb-2">
        ▸ {entry.data.category}
      </p>
      <h3 class="heading text-2xl md:text-3xl leading-tight">
        {entry.data.title}
      </h3>
    </div>
    {
      entry.data.featured && (
        <span class={`inline-flex items-center gap-1 border-[2px] border-ink rounded-full px-2.5 py-0.5 text-[10px] font-bold uppercase shadow-neo-xs ${tone === "yellow" ? "bg-pink text-ink" : "bg-yellow text-ink"}`}>
          ★ Featured
        </span>
      )
    }
  </header>

  <p class="text-sm md:text-base leading-snug opacity-90">
    {entry.data.description}
  </p>

  {
    entry.data.outcome && (
      <p class="mono inline-flex items-start gap-2 text-xs font-bold uppercase tracking-wider bg-ink text-bg px-3 py-2 w-fit max-w-full break-words">
        <Icon name="lucide:trending-up" class="h-4 w-4 mt-0.5 shrink-0" />
        <span>{entry.data.outcome}</span>
      </p>
    )
  }

  {
    entry.data.stack.length > 0 && (
      <ul class="flex flex-wrap gap-1.5">
        {entry.data.stack.map((s) => (
          <li>
            <TagPill tone={tagTone} size="sm">
              {s}
            </TagPill>
          </li>
        ))}
      </ul>
    )
  }

  {
    (entry.data.liveUrl || entry.data.githubUrl) && (
      <div class="mt-auto flex flex-wrap gap-2.5 pt-2">
        {entry.data.liveUrl && (
          <NeoButton href={entry.data.liveUrl} variant="ink" size="sm">
            <Icon name="lucide:external-link" class="h-3.5 w-3.5" />
            Live
          </NeoButton>
        )}
        {entry.data.githubUrl && (
          <NeoButton href={entry.data.githubUrl} variant="secondary" size="sm">
            <Icon name="lucide:github" class="h-3.5 w-3.5" />
            Source
          </NeoButton>
        )}
      </div>
    )
  }
</article>
