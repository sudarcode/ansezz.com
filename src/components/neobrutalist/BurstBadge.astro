---
type Tone = "yellow" | "pink" | "cyan" | "green" | "red" | "blue" | "purple";
type Size = "sm" | "md" | "lg";

interface Props {
  tone?: Tone;
  size?: Size;
  class?: string;
}

const { tone = "yellow", size = "md", class: className = "" } = Astro.props;

const sizeClass: Record<Size, string> = {
  sm: "w-16 h-16 text-sm",
  md: "w-24 h-24 text-base",
  lg: "w-32 h-32 text-lg",
};

const toneVar: Record<Tone, string> = {
  yellow: "var(--color-yellow)",
  pink: "var(--color-pink)",
  cyan: "var(--color-cyan)",
  green: "var(--color-green)",
  red: "var(--color-red)",
  blue: "var(--color-blue)",
  purple: "var(--color-purple)",
};

const burstPath =
  "M50 0 L58 14 L72 6 L73 22 L88 22 L80 36 L96 44 L80 52 L92 66 L76 66 L78 82 L62 74 L54 90 L46 82 L34 96 L28 80 L12 88 L18 72 L4 64 L18 56 L4 44 L20 38 L8 24 L24 24 L20 8 L36 12 L42 0 Z";
---

<div
  class:list={[
    "relative inline-flex items-center justify-center display font-black",
    sizeClass[size],
    className,
  ]}
>
  <svg
    viewBox="0 0 100 100"
    class="absolute inset-0 w-full h-full drop-shadow-[3px_3px_0_var(--color-ink)]"
    aria-hidden="true"
  >
    <path
      d={burstPath}
      fill={toneVar[tone]}
      stroke="var(--color-ink)"
      stroke-width="3"
      stroke-linejoin="round"
    />
  </svg>
  <span class="relative z-10 text-ink leading-none"><slot /></span>
</div>
