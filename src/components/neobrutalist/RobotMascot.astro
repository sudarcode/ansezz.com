---
type Tone = "yellow" | "pink" | "cyan" | "green";

interface Props {
  tone?: Tone;
  size?: number;
  class?: string;
}

const { tone = "yellow", size = 160, class: className = "" } = Astro.props;

const toneVar: Record<Tone, string> = {
  yellow: "var(--color-yellow)",
  pink: "var(--color-pink)",
  cyan: "var(--color-cyan)",
  green: "var(--color-green)",
};

const fill = toneVar[tone];
---

<svg
  width={size}
  height={size}
  viewBox="0 0 200 200"
  class={className}
  role="img"
  aria-label="ansezz robot mascot"
>
  <title>ansezz robot mascot</title>
  <!-- antenna -->
  <line x1="100" y1="20" x2="100" y2="40" stroke="var(--color-ink)" stroke-width="4" />
  <circle cx="100" cy="18" r="6" fill={fill} stroke="var(--color-ink)" stroke-width="3" />
  <!-- head -->
  <rect x="50" y="40" width="100" height="80" rx="6" fill={fill} stroke="var(--color-ink)" stroke-width="4" />
  <!-- screen -->
  <rect x="62" y="56" width="76" height="40" rx="3" fill="var(--color-paper)" stroke="var(--color-ink)" stroke-width="3" />
  <!-- eyes -->
  <rect x="74" y="68" width="14" height="14" fill="var(--color-ink)" />
  <rect x="112" y="68" width="14" height="14" fill="var(--color-ink)" />
  <!-- mouth -->
  <rect x="80" y="104" width="40" height="6" fill="var(--color-ink)" />
  <!-- neck -->
  <rect x="88" y="120" width="24" height="10" fill="var(--color-ink)" />
  <!-- body -->
  <rect x="40" y="130" width="120" height="50" rx="4" fill="var(--color-paper)" stroke="var(--color-ink)" stroke-width="4" />
  <!-- chest light -->
  <circle cx="100" cy="155" r="10" fill={fill} stroke="var(--color-ink)" stroke-width="3" />
  <!-- side buttons -->
  <circle cx="55" cy="148" r="3" fill="var(--color-ink)" />
  <circle cx="55" cy="162" r="3" fill="var(--color-ink)" />
  <circle cx="145" cy="148" r="3" fill="var(--color-ink)" />
  <circle cx="145" cy="162" r="3" fill="var(--color-ink)" />
</svg>
