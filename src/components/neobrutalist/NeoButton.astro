---
import { externalLinkAttrs } from "@/lib/links";

type Variant = "primary" | "secondary" | "ghost" | "danger" | "ink";
type Size = "sm" | "md" | "lg";
type ElementTag = "button" | "a";

export interface Props {
  variant?: Variant;
  size?: Size;
  href?: string;
  type?: "button" | "submit" | "reset";
  disabled?: boolean;
  ariaLabel?: string;
  class?: string;
  fullWidth?: boolean;
}

const {
  variant = "primary",
  size = "md",
  href,
  type = "button",
  disabled = false,
  ariaLabel,
  class: className = "",
  fullWidth = false,
} = Astro.props;

const variantClass: Record<Variant, string> = {
  primary: "bg-yellow text-ink",
  secondary: "bg-paper text-ink",
  ghost: "bg-transparent text-ink hover:bg-yellow",
  danger: "bg-red text-ink",
  ink: "bg-ink text-bg",
};

const sizeClass: Record<Size, string> = {
  sm: "px-4 py-2 text-xs",
  md: "px-5 py-2.5 text-sm",
  lg: "px-7 py-3.5 text-base",
};

const Tag: ElementTag = href ? "a" : "button";
const externalAttrs = href ? externalLinkAttrs(href) : {};
---

<Tag
  href={href}
  type={!href ? type : undefined}
  disabled={!href ? disabled : undefined}
  aria-disabled={disabled || undefined}
  aria-label={ariaLabel}
  data-neo-hover
  {...externalAttrs}
  class:list={[
    "inline-flex items-center justify-center gap-2 font-bold uppercase tracking-wide border-[3px] border-ink rounded-[6px] shadow-neo-sm transition-all duration-150 hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-neo-md disabled:opacity-50 disabled:cursor-not-allowed disabled:pointer-events-none whitespace-nowrap",
    variantClass[variant],
    sizeClass[size],
    fullWidth ? "w-full" : "",
    className,
  ]}
>
  <slot />
</Tag>
