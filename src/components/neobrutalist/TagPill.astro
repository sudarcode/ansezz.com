---
import { externalLinkAttrs } from "@/lib/links";

type Tone = "paper" | "yellow" | "pink" | "cyan" | "green" | "red" | "blue" | "ink";
type Size = "sm" | "md";

interface Props {
  tone?: Tone;
  size?: Size;
  href?: string;
  active?: boolean;
  class?: string;
}

const {
  tone = "paper",
  size = "md",
  href,
  active = false,
  class: className = "",
} = Astro.props;

const toneClass: Record<Tone, string> = {
  paper: "bg-paper text-ink",
  yellow: "bg-yellow text-ink",
  pink: "bg-pink text-ink",
  cyan: "bg-cyan text-ink",
  green: "bg-green text-ink",
  red: "bg-red text-ink",
  blue: "bg-blue text-paper",
  ink: "bg-ink text-paper",
};

const sizeClass: Record<Size, string> = {
  sm: "px-2.5 py-1 text-xs",
  md: "px-3.5 py-1.5 text-sm",
};

const Tag = href ? "a" : "span";
const externalAttrs = href ? externalLinkAttrs(href) : {};
---

<Tag
  href={href}
  {...externalAttrs}
  class:list={[
    "inline-flex items-center font-bold uppercase tracking-wide border-[2px] border-ink rounded-[3px] whitespace-nowrap",
    toneClass[tone],
    sizeClass[size],
    href ? "shadow-neo-sm transition-all hover:-translate-x-0.5 hover:-translate-y-0.5 hover:shadow-neo-md" : "",
    active ? "shadow-neo-md -translate-x-0.5 -translate-y-0.5" : "",
    className,
  ]}
>
  <slot />
</Tag>
