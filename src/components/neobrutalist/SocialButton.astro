---
import { Icon } from "astro-icon/components";
import { externalLinkAttrs } from "@/lib/links";

type Tone = "paper" | "yellow" | "pink" | "cyan" | "green" | "purple" | "ink";
type Size = "sm" | "md" | "lg";

interface Props {
  href: string;
  icon: string;
  label: string;
  sublabel?: string;
  tone?: Tone;
  size?: Size;
  class?: string;
}

const {
  href,
  icon,
  label,
  sublabel,
  tone = "paper",
  size = "md",
  class: className = "",
} = Astro.props;

const toneClass: Record<Tone, string> = {
  paper: "bg-paper text-ink",
  yellow: "bg-yellow text-ink",
  pink: "bg-pink text-ink",
  cyan: "bg-cyan text-ink",
  green: "bg-green text-ink",
  purple: "bg-purple text-paper",
  ink: "bg-ink text-bg",
};

const sizeClass: Record<Size, string> = {
  sm: "h-14 w-14 [&>svg]:h-5 [&>svg]:w-5",
  md: "h-20 w-20 [&>svg]:h-7 [&>svg]:w-7",
  lg: "h-24 w-24 [&>svg]:h-9 [&>svg]:w-9",
};

const externalAttrs = externalLinkAttrs(href);
---

<a
  href={href}
  {...externalAttrs}
  aria-label={sublabel ? `${label} — ${sublabel}` : label}
  data-neo-hover
  class:list={[
    "group inline-flex flex-col items-center justify-center gap-1.5 border-[3px] border-ink rounded-[4px] shadow-neo-md transition-all duration-150 hover:-translate-x-1 hover:-translate-y-1 hover:shadow-neo-lg",
    toneClass[tone],
    sizeClass[size],
    className,
  ]}
>
  <Icon name={icon} aria-hidden="true" />
  <span class="sr-only">{label}</span>
</a>
